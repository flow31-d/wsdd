#!/usr/bin/env bash
set -euo pipefail

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
project_root="$(cd "$script_dir/../.." && pwd)"
command="${1:-help}"
shift || true

cd "$project_root"

_context_get() {
  local key_path="${1:-}"
  [[ -f +context.json ]] || return 0
  command -v python3 >/dev/null || return 0
  WSD_KEY_PATH="$key_path" python3 - <<'PY' 2>/dev/null || true
import json
import os

path = os.environ.get("WSD_KEY_PATH", "")
with open("+context.json", encoding="utf-8") as fh:
    data = json.load(fh)
cur = data
for part in path.split("."):
    if not part:
        continue
    if not isinstance(cur, dict) or part not in cur:
        raise SystemExit(0)
    cur = cur[part]
if isinstance(cur, bool):
    print("true" if cur else "false")
elif cur is None:
    print("")
else:
    print(cur)
PY
}

_git_mode() {
  local mode
  mode="$(_context_get git_governance.mode)"
  [[ -n "$mode" ]] || mode="none"
  printf "%s\n" "$mode"
}

_git_current_branch() {
  git rev-parse --abbrev-ref HEAD 2>/dev/null || true
}

_git_upstream() {
  git rev-parse --abbrev-ref --symbolic-full-name '@{u}' 2>/dev/null || true
}

_git_has_changes_for_pr() {
  local base_ref="$1"
  [[ -n "$base_ref" ]] || return 1
  git rev-list --count "${base_ref}..HEAD" 2>/dev/null | grep -qE '^[1-9][0-9]*$'
}

_git_base_ref() {
  local default_branch="$1"
  if [[ -n "$default_branch" ]] && git show-ref --verify --quiet "refs/remotes/origin/${default_branch}"; then
    printf "origin/%s\n" "$default_branch"
    return 0
  fi
  if [[ -n "$default_branch" ]] && git show-ref --verify --quiet "refs/heads/${default_branch}"; then
    printf "%s\n" "$default_branch"
    return 0
  fi
  printf "%s\n" "${default_branch:-main}"
}

_json_get() {
  local file="$1"
  local path="$2"
  [[ -f "$file" ]] || return 1

  node - "$file" "$path" <<'NODE' 2>/dev/null
const fs = require('fs');

const filePath = process.argv[2];
const keyPath = process.argv[3];

let data;
try {
  data = JSON.parse(fs.readFileSync(filePath, 'utf8'));
} catch (_error) {
  process.exit(1);
}

const keys = String(keyPath).split('.').filter(Boolean);
let value = data;
for (const key of keys) {
  if (!value || typeof value !== 'object' || !Object.prototype.hasOwnProperty.call(value, key)) {
    process.exit(1);
  }
  value = value[key];
}

if (value === undefined || value === null) {
  process.exit(1);
}

if (typeof value === 'string' || typeof value === 'number' || typeof value === 'boolean') {
  process.stdout.write(String(value));
} else {
  process.stdout.write(JSON.stringify(value));
}
NODE
}

_normalize_version() {
  local version="$1"
  version="${version#v}"
  printf "%s" "$version"
}

_version_cmp() {
  local a="$1"
  local b="$2"
  a="$(_normalize_version "$a")"
  b="$(_normalize_version "$b")"

  [[ -n "$a" && -n "$b" ]] || { echo "unknown"; return; }
  if [[ "$a" == "$b" ]]; then
    echo "eq"
    return
  fi
  if [[ "$(printf '%s\n%s\n' "$a" "$b" | sort -V | head -n 1)" == "$a" ]]; then
    echo "lt"
  else
    echo "gt"
  fi
}

_wsd_version_record() {
  local root="$1"
  local as_json="${2:-0}"
  local norm_root="${root%/}"

  local cfg_path="${norm_root}/+wsd/config.json"
  local project_path="${norm_root}/+context.json"
  local source_version_path
  local source_candidate_path
  local project_name
  local installed_version
  local installed_at
  local source_path
  local source_version="n/a"
  local status="not-installed"
  local source_match_raw
  local cfg_exists=0
  local cmp

  project_name="$(_json_get "$project_path" "project.name" || true)"
  installed_version="$(_json_get "$cfg_path" "version" || true)"
  installed_at="$(_json_get "$cfg_path" "installed_at" || true)"
  source_path="$(_json_get "$cfg_path" "wsd_source" || true)"
  [[ -f "$cfg_path" ]] && cfg_exists=1

  if [[ -z "$project_name" ]]; then
    project_name="$(basename "$norm_root")"
  fi
  if [[ -z "$installed_version" ]]; then
    installed_version="n/a"
  fi
  if [[ -z "$installed_at" ]]; then
    installed_at="n/a"
  fi
  if [[ -n "$source_path" ]]; then
    if [[ "$source_path" = /* ]]; then
      source_version_path="$source_path/package.json"
    else
      source_candidate_path="${norm_root}/${source_path}/package.json"
      if [[ -f "$source_candidate_path" ]]; then
        source_version_path="$source_candidate_path"
      else
        source_version_path="${norm_root}/$source_path/package.json"
      fi
    fi
    if [[ -f "$source_version_path" ]]; then
      source_path="${source_version_path%/package.json}"
    fi
    source_version="$(_json_get "$source_version_path" "version" || true)"
    [[ -n "$source_version" ]] || source_version="n/a"
  else
    source_path="n/a"
  fi

  if [[ "$cfg_exists" -eq 1 && "$installed_version" == "n/a" ]]; then
    status="unreadable"
  elif [[ -z "${installed_version// /}" ]]; then
    status="unreadable"
  elif [[ "$installed_version" != "n/a" && "$source_version" != "n/a" ]]; then
    cmp="$(_version_cmp "$installed_version" "$source_version")"
    if [[ "$cmp" == "eq" ]]; then
      status="aligned"
      source_match_raw="true"
    elif [[ "$cmp" == "lt" ]]; then
      status="behind-source"
      source_match_raw="false"
    elif [[ "$cmp" == "gt" ]]; then
      status="ahead-of-source"
      source_match_raw="n/a"
    else
      status="unknown"
      source_match_raw="n/a"
    fi
  elif [[ -f "$cfg_path" ]]; then
    status="source-unknown"
  else
    status="not-installed"
  fi

  if [[ -z "$source_match_raw" ]]; then
    source_match_raw="n/a"
  fi

    if [[ "$as_json" == "1" ]]; then
      node - "$norm_root" "$project_name" "$installed_version" "$installed_at" "$source_path" "$source_version" "$status" "$source_match_raw" <<'NODE'
const [
  ,
  ,
  path,
  project,
  installed_version,
  installed_at,
  source_path,
  source_version,
  status,
  source_match
] = process.argv;
console.log(JSON.stringify({
  path,
  project,
  installed_version,
  installed_at,
  source_path,
  source_version,
  status,
  source_match,
}));
NODE
  else
      printf '%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\n' \
      "$norm_root" "$project_name" "$installed_version" "$installed_at" "$source_path" "$source_version" "$status" "$source_match_raw"
  fi
}

_wsd_version_report() {
  local as_json=0
  local inventory=0
  local -a roots=()
  local max_depth=4
  local arg

  while [[ "$#" -gt 0 ]]; do
    arg="$1"
    case "$arg" in
      --json)
        as_json=1
        shift
        ;;
      --inventory|--scan)
        inventory=1
        shift
        ;;
      --root|--path)
        [[ -n "${2-}" ]] || { echo "FAIL: --root precisa de valor" >&2; exit 1; }
        roots+=("$2")
        shift 2
        ;;
      --max-depth)
        [[ -n "${2-}" ]] || { echo "FAIL: --max-depth precisa de valor" >&2; exit 1; }
        max_depth="$2"
        shift 2
        ;;
      --help|-h)
        cat <<USAGE
Usage: ./+wsd/bin/wsd version [options]
  --json             saída JSON
  --inventory        varrer diretórios buscando projetos com +wsd/config.json
  --scan             sinônimo de --inventory
  --path <dir>       diretório para varredura (pode repetir)
  --max-depth <n>    profundidade máxima do find em inventory mode (padrão: 4)
  --help, -h         ajuda

Sem flags, consulta WSD apenas no diretório atual.
Exemplos:
  ./+wsd/bin/wsd version
  ./+wsd/bin/wsd version --inventory --path .
  ./+wsd/bin/wsd version --json --inventory --path ~/projects
USAGE
        return 0
        ;;
      *)
        echo "FAIL: argumento desconhecido em version: $arg" >&2
        echo "Hint: use ./+wsd/bin/wsd version --help" >&2
        return 1
        ;;
    esac
  done

  if (( inventory == 1 )); then
    local -a project_roots=()
    local -A seen=()
    local root

    if [[ ${#roots[@]} -eq 0 ]]; then
      roots+=(".")
    fi

    for root in "${roots[@]}"; do
      if [[ -f "$root/+wsd/config.json" ]]; then
        [[ -z "${seen[$root]-}" ]] && { seen["$root"]=1; project_roots+=("$root"); }
        continue
      fi

      if [[ ! -d "$root" ]]; then
        echo "WARN: diretório não encontrado em inventory mode: $root" >&2
        continue
      fi

      while IFS= read -r -d '' cfg_path; do
        local candidate="${cfg_path%/+wsd/config.json}"
        [[ -z "${seen[$candidate]-}" ]] && { seen["$candidate"]=1; project_roots+=("$candidate"); }
      done < <(find "$root" -maxdepth "$max_depth" -type f -path "*/+wsd/config.json" -print0)
    done

    if [[ ${#project_roots[@]} -eq 0 ]]; then
      echo "FAIL: nenhum +wsd/config.json encontrado em: ${roots[*]}" >&2
      return 1
    fi

    readarray -t project_roots < <(printf '%s\n' "${project_roots[@]}" | sort -u)

    if [[ "$as_json" == "1" ]]; then
      local root_path
      local first_record=1
      echo '['
      for root_path in "${project_roots[@]}"; do
        [[ -f "$root_path/+wsd/config.json" ]] || continue
        if [[ $first_record -eq 0 ]]; then
          echo ','
        fi
        printf '  '
        _wsd_version_record "$root_path" 1
        first_record=0
      done
      echo ']'
    else
      printf 'PATH\tPROJETO\tVERSION\tINSTALLED_AT\tSOURCE_PATH\tSOURCE_VERSION\tSTATUS\tSOURCE_MATCH\n'
      local path
      for path in "${project_roots[@]}"; do
        [[ -f "$path/+wsd/config.json" ]] || continue
        _wsd_version_record "$path" 0
      done
    fi
  else
    _wsd_version_record "." "$as_json"
  fi
}

case "$command" in
  start)
    echo "== WSD Start =="
    git status --short --branch
    git branch -vv
    git remote -v
    git remote show origin 2>/dev/null || true
    if [[ -f scripts/wsd_check.sh ]]; then
      bash scripts/wsd_check.sh --risk L0 .
    fi
    if [[ -f +specs/HANDOFF.md ]]; then
      echo "-- HANDOFF.md (last session) --"
      head -20 +specs/HANDOFF.md
    fi
    find +specs/features -maxdepth 2 -type f -name 'spec.md' 2>/dev/null | sort || true
    find +specs/quick -maxdepth 1 -type f -name '*.md' 2>/dev/null | sort || true
    gh pr list --state open --limit 20 2>/dev/null || true
    ;;
  check)
    if [[ -f scripts/wsd_check.sh ]]; then
      bash scripts/wsd_check.sh "$@"
    else
      echo "FAIL: scripts/wsd_check.sh not found" >&2
      exit 1
    fi
    ;;
  finish)
    echo "== WSD Finish =="
    git status --short --branch
    git diff --stat
    git diff --check
    git log -1 --date=short --pretty='last=%ad | %h | %s'
    if [[ -f scripts/wsd_check.sh ]]; then
      bash scripts/wsd_check.sh --risk L0 .
    fi
    gh pr status 2>/dev/null || true

    # --- Generate HANDOFF.md ---
    _today="$(date '+%Y-%m-%d')"
    _now="$(date '+%Y-%m-%d %H:%M')"
    _branch="$(git rev-parse --abbrev-ref HEAD 2>/dev/null || echo 'unknown')"
    _last_commit="$(git log -1 --pretty='%h - %s (%ad)' --date=short 2>/dev/null || echo '(no commits)')"
    _git_state_short="$(git status --short 2>/dev/null)"
    _recent="$(git log --oneline -5 2>/dev/null | sed 's/^/- /' || echo '- (none)')"
    _dirty="$(git status --short 2>/dev/null | grep -v '^??' | sed 's/^/- /' || true)"
    [[ -z "$_dirty" ]] && _dirty="(working tree clean)"
    _specs_list="$(find +specs/features -maxdepth 2 -name 'spec.md' 2>/dev/null | sed 's/^/- /' || true)"
    [[ -z "$_specs_list" ]] && _specs_list="- (nenhuma)"

    mkdir -p +specs
    {
      printf "# HANDOFF -- %s\n\n" "$_now"
      printf "## Sessao\n\n"
      printf -- "- Branch: %s\n" "$_branch"
      printf -- "- Ultimo commit: %s\n" "$_last_commit"
      if [[ -z "$_git_state_short" ]]; then
        printf -- "- Estado: limpo\n"
      else
        printf -- "- Estado: sujo (uncommitted changes -- ver abaixo)\n"
      fi
      printf "\n## Concluido nesta sessao\n\n"
      printf "(ultimos 5 commits -- editar conforme necessario)\n"
      printf "%s\n" "$_recent"
      printf "\n## Em andamento\n\n"
      printf "%s\n" "$_dirty"
      printf "\n## Proximos Passos\n\n"
      printf -- "- [ ] (preencher)\n"
      printf "\n## Referencias\n\n"
      printf -- "- STATE: +specs/project/STATE.md\n"
      printf -- "- Specs:\n"
      printf "%s\n" "$_specs_list"
    } > "+specs/HANDOFF.md"

    echo ""
    echo ">> +specs/HANDOFF.md gerado"

    # --- Prompts STATE.md (somente em terminal interativo) ---
    if [[ -f +specs/project/STATE.md ]]; then
      if ! command -v python3 >/dev/null; then
        echo "info: python3 ausente -- STATE.md prompts pulados; preencher manualmente"
      elif [[ ! -t 0 ]]; then
        echo "info: STATE.md prompts pulados (stdin nao-interativo)"
      else
        _state_insert() {
          WSD_FILE="$1" WSD_SECTION="$2" WSD_ROW="$3" python3 -c "
import os
f = os.environ['WSD_FILE']
sec = os.environ['WSD_SECTION']
row = os.environ['WSD_ROW']
lines = open(f).readlines()
out = []
in_sec = False
done = False
for l in lines:
    out.append(l)
    if sec in l:
        in_sec = True
    elif in_sec and not done and l.startswith('|---'):
        out.append(row + '\n')
        done = True
        in_sec = False
open(f, 'w').writelines(out)
"
        }

        echo ""
        echo "== Captura de Memoria Operacional =="

        printf "Houve licoes aprendidas nesta sessao? [s/N] "
        read -r _resp
        if [[ "$_resp" =~ ^[Ss]$ ]]; then
          printf "  Licao (1 linha): "
          read -r _licao
          if [[ -n "$_licao" ]]; then
            printf "  Como prevenir? (1 linha): "
            read -r _prevencao
            _state_insert "+specs/project/STATE.md" "Aprendidas" "| $_today | $_licao | $_prevencao |"
            echo "  ok: licao registrada em STATE.md"
          fi
        fi

        printf "Houve decisoes arquiteturais ou de metodo? [s/N] "
        read -r _resp
        if [[ "$_resp" =~ ^[Ss]$ ]]; then
          printf "  Decisao (1 linha): "
          read -r _decisao
          if [[ -n "$_decisao" ]]; then
            printf "  Racional (1 linha): "
            read -r _racional
            _state_insert "+specs/project/STATE.md" "## Decis" "| $_today | $_decisao | $_racional |"
            echo "  ok: decisao registrada em STATE.md"
          fi
        fi

        printf "Ha bloqueadores ativos? [s/N] "
        read -r _resp
        if [[ "$_resp" =~ ^[Ss]$ ]]; then
          printf "  Bloqueador (1 linha): "
          read -r _bloqueador
          if [[ -n "$_bloqueador" ]]; then
            printf "  Impacto (1 linha): "
            read -r _impacto
            _state_insert "+specs/project/STATE.md" "## Bloqueadores Ativos" "| $_today | $_bloqueador | $_impacto | Em analise |"
            echo "  ok: bloqueador registrado em STATE.md"
          fi
        fi
      fi
    fi

    # --- Generate snapshot ---
    if [[ -f +wsd/bin/wsd-snapshot.cjs ]]; then
      node +wsd/bin/wsd-snapshot.cjs 2>/dev/null && echo ">> +wsd/snapshot.json atualizado" || true
    fi
    ;;
  doctor)
    echo "== WSD Doctor =="
    test -f +wsd/config.json && echo "ok: +wsd/config.json" || echo "missing: +wsd/config.json"
    test -f +wsd/docs/10_matriz_sincronizacao_notas.md && echo "ok: +wsd/docs/10_matriz_sincronizacao_notas.md" || echo "missing: +wsd/docs/10_matriz_sincronizacao_notas.md"
    test -f +wsd/schemas/context.schema.json && echo "ok: +wsd/schemas/context.schema.json" || echo "missing: +wsd/schemas/context.schema.json"
    test -x +wsd/bin/wsd-validate-context.cjs && echo "ok: +wsd/bin/wsd-validate-context.cjs" || echo "missing: +wsd/bin/wsd-validate-context.cjs"
    test -f AGENTS.md && echo "ok: AGENTS.md" || echo "missing: AGENTS.md"
    test -f +context.json && echo "ok: +context.json" || echo "missing: +context.json"
    test -d +specs && echo "ok: +specs" || echo "missing: +specs"
    test -f +specs/project/STATE.md && echo "ok: +specs/project/STATE.md" || echo "missing: +specs/project/STATE.md"
    test -f +specs/project/PROJECT.md && echo "ok: +specs/project/PROJECT.md" || echo "missing: +specs/project/PROJECT.md"
    if [[ -d +specs/codebase ]]; then
      echo "ok: +specs/codebase (brownfield)"
    else
      echo "info: +specs/codebase absent (greenfield install)"
    fi
    command -v git >/dev/null && echo "ok: git" || echo "missing: git"
    command -v node >/dev/null && echo "ok: node" || echo "missing: node (schema validation will skip)"
    command -v python3 >/dev/null && echo "ok: python3" || echo "missing: python3"
    command -v gh >/dev/null && echo "ok: gh optional" || echo "missing: gh optional"
    echo "ok: git namespace available (doctor, preflight, pr-check)"
    if [[ -f +wsd/party-mode/agents-wsd.csv ]]; then
      echo "ok: party-mode instalado"
    else
      echo "info: party-mode ausente (reinstale com --force para instalar)"
    fi
    for hook in pre-commit commit-msg pre-push; do
      if [[ -x ".git/hooks/$hook" ]]; then
        echo "ok: .git/hooks/$hook"
      else
        echo "missing: .git/hooks/$hook (run: ./+wsd/bin/wsd hooks)"
      fi
    done
    ;;
  hooks)
    if [[ -d scripts/git-hooks ]]; then
      [[ -d .git/hooks ]] || { echo "FAIL: .git/hooks not found — is this a Git repo?" >&2; exit 1; }
      for hook in scripts/git-hooks/*; do
        hookname="$(basename "$hook")"
        cp "$hook" ".git/hooks/$hookname"
        chmod +x ".git/hooks/$hookname"
        echo "ok: installed .git/hooks/$hookname"
      done
    else
      echo "FAIL: scripts/git-hooks not found — run wsd-method install --force to regenerate" >&2
      exit 1
    fi
    ;;
  update)
    if [[ ! -f +wsd/config.json ]]; then
      echo "FAIL: +wsd/config.json not found — run wsd-method install first" >&2
      exit 1
    fi
    _wsd_src="$(python3 -c "import json; print(json.load(open('+wsd/config.json')).get('wsd_source',''))" 2>/dev/null || echo '')"
    if [[ -n "$_wsd_src" && -f "$_wsd_src/bin/wsd-method.js" ]]; then
      node "$_wsd_src/bin/wsd-method.js" update --directory .
    else
      echo "warn: wsd_source ausente ou invalido em +wsd/config.json"
      echo "Execute: node /caminho/para/wsd/bin/wsd-method.js update --directory ."
    fi
    ;;
  git)
    subcommand="${1:-help}"
    shift || true
    mode="$(_git_mode)"
    case "$subcommand" in
      doctor)
        echo "== WSD Git Doctor =="
        echo "mode: $mode"
        git rev-parse --is-inside-work-tree >/dev/null 2>&1 || { echo "FAIL: not a Git repository" >&2; exit 1; }
        branch="$(_git_current_branch)"
        upstream="$(_git_upstream)"
        remote="$(git remote get-url origin 2>/dev/null || true)"
        default_branch="$(_context_get git_governance.default_branch)"
        [[ -n "$default_branch" ]] || default_branch="$(_context_get repository.default_branch)"
        echo "branch: ${branch:-unknown}"
        echo "upstream: ${upstream:-missing}"
        echo "remote: ${remote:-missing}"
        echo "default_branch: ${default_branch:-unknown}"
        if [[ "$mode" == "full" ]]; then
          if command -v gh >/dev/null; then
            echo "ok: gh available"
            gh auth status >/dev/null 2>&1 && echo "ok: gh authenticated" || echo "warn: gh not authenticated"
          else
            echo "warn: gh missing (full mode can still use manual PR flow)"
          fi
          if [[ "$remote" == *github.com* ]]; then
            echo "ok: origin looks like GitHub"
          else
            echo "warn: origin is not a GitHub remote"
          fi
        fi
        ;;
      preflight)
        echo "== WSD Git Preflight =="
        fail_count=0
        git rev-parse --is-inside-work-tree >/dev/null 2>&1 || { echo "FAIL: not a Git repository" >&2; exit 1; }
        branch="$(_git_current_branch)"
        upstream="$(_git_upstream)"
        status_short="$(git status --short)"
        canonical_path="$(_context_get environment.canonical_path)"
        canonical_host="$(_context_get environment.canonical_host)"
        current_host="$(hostname 2>/dev/null || true)"
        echo "mode: $mode"
        echo "branch: ${branch:-unknown}"
        echo "upstream: ${upstream:-missing}"
        if [[ -n "$canonical_path" && "$canonical_path" != "$(pwd)" ]]; then
          echo "warn: current path differs from canonical_path ($canonical_path)"
        fi
        if [[ -n "$canonical_host" && -n "$current_host" && "$canonical_host" != "$current_host" ]]; then
          echo "warn: current host differs from canonical_host ($canonical_host)"
        fi
        if [[ -n "$status_short" ]]; then
          echo "FAIL: worktree is dirty"
          printf "%s\n" "$status_short"
          fail_count=$((fail_count + 1))
        else
          echo "ok: worktree clean"
        fi
        if [[ -z "$upstream" ]]; then
          echo "warn: upstream missing"
        fi
        [[ "$fail_count" -eq 0 ]] || exit 1
        ;;
      pr-check)
        echo "== WSD Git PR Check =="
        git rev-parse --is-inside-work-tree >/dev/null 2>&1 || { echo "FAIL: not a Git repository" >&2; exit 1; }
        fail_count=0
        branch="$(_git_current_branch)"
        upstream="$(_git_upstream)"
        remote="$(git remote get-url origin 2>/dev/null || true)"
        default_branch="$(_context_get git_governance.default_branch)"
        [[ -n "$default_branch" ]] || default_branch="$(_context_get repository.default_branch)"
        [[ -n "$default_branch" ]] || default_branch="main"
        base_ref="$(_git_base_ref "$default_branch")"
        echo "mode: $mode"
        echo "branch: ${branch:-unknown}"
        echo "upstream: ${upstream:-missing}"
        echo "remote: ${remote:-missing}"
        echo "base_ref: ${base_ref:-unknown}"
        if [[ "$branch" == "$default_branch" || "$branch" == "main" || "$branch" == "master" ]]; then
          echo "FAIL: PR deve sair de branch dedicada, nao de $branch"
          fail_count=$((fail_count + 1))
        fi
        if [[ -n "$(git status --short 2>/dev/null)" ]]; then
          echo "FAIL: worktree is dirty"
          fail_count=$((fail_count + 1))
        fi
        if ! _git_has_changes_for_pr "$base_ref"; then
          echo "FAIL: nao ha commits ahead de ${base_ref} prontos para PR"
          fail_count=$((fail_count + 1))
        fi
        if [[ "$mode" == "full" && "$remote" != *github.com* ]]; then
          echo "warn: origin nao parece ser GitHub"
        fi
        if [[ "$mode" == "full" && -z "$upstream" ]]; then
          echo "warn: upstream ausente; use git push -u origin $branch antes do PR"
        fi
        [[ "$fail_count" -eq 0 ]] || exit 1
        echo "ok: pr-check passed"
        ;;
      help|--help|-h)
        echo "Usage: ./+wsd/bin/wsd git doctor|preflight|pr-check"
        ;;
      *)
        echo "Unknown WSD git command: $subcommand" >&2
        echo "Usage: ./+wsd/bin/wsd git doctor|preflight|pr-check" >&2
        exit 1
        ;;
    esac
    ;;
  party)
    subcommand="${1:-help}"
    shift || true
    case "$subcommand" in
      status)
        if [[ -f +wsd/party-mode/agents-wsd.csv ]]; then
          count=$(tail -n +2 +wsd/party-mode/agents-wsd.csv | grep -c '' || true)
          echo "ok: party-mode instalado — $count agentes disponíveis"
        else
          echo "FAIL: party-mode não instalado — +wsd/party-mode/agents-wsd.csv ausente" >&2
          exit 1
        fi
        ;;
      list-agents)
        [[ -f +wsd/party-mode/agents-wsd.csv ]] || { echo "FAIL: +wsd/party-mode/agents-wsd.csv ausente" >&2; exit 1; }
        command -v python3 >/dev/null || { echo "FAIL: python3 necessário para list-agents" >&2; exit 1; }
        python3 - <<'PY'
import csv
with open("+wsd/party-mode/agents-wsd.csv", encoding="utf-8") as f:
    for row in csv.DictReader(f):
        icon = row.get("icon", "•")
        name = row.get("displayName", row.get("name", "?"))
        domain = row.get("domain", "?")
        title = row.get("title", "")
        print(f"{icon} {name:<20s} ({domain:<4s}) — {title}")
PY
        ;;
      when-to-use)
        cat <<'USAGE'
== WSD Party Mode — Quando Usar ==

L0 trivial?        → Skip (use quick-flow solo)
Em EXECUTE?        → Skip (spec já diz o que fazer)
Já decidido?       → Skip (use 1 agente para validar)
Hotfix urgente?    → Skip

Contexto              Agentes selecionados              Tempo
SPECIFY/Brainstorm    analyst + pm + brainstorming-coach ~20 min
DESIGN/Arquitetura    architect + dev + module-builder   ~25 min
RISK L1               qa + architect + pm               ~20 min
RISK L2 (obrigatório) tea + test-architect + sys-arch   ~30 min
CODE REVIEW           dev + test-architect + architect  ~20 min
PROCESS/Ciclo         wsd-master + scrum-master + workflow-builder ~15 min

Comando Claude Code: /wsd-party-mode
USAGE
        ;;
      help|*)
        echo "Usage: ./+wsd/bin/wsd party <subcommand>"
        echo "  status       — verifica se party-mode está instalado"
        echo "  list-agents  — lista os 26 agentes disponíveis"
        echo "  when-to-use  — decision tree de quando usar"
        ;;
    esac
    ;;
  snapshot)
    if [[ ! -f +wsd/bin/wsd-snapshot.cjs ]]; then
      echo "FAIL: +wsd/bin/wsd-snapshot.cjs não encontrado — reinstale com wsd-method install --force" >&2
      exit 1
    fi
    node +wsd/bin/wsd-snapshot.cjs
    ;;
  lovable)
    subcommand="${1:-help}"
    shift || true
    _lovable_enabled="$(_context_get lovable_integration.enabled)"
    case "$subcommand" in
      doctor)
        echo "== WSD Lovable Doctor =="
        if [[ "$_lovable_enabled" != "true" ]]; then
          echo "FAIL: +context.json não declara lovable_integration.enabled=true" >&2
          echo "Hint: reinstale com --profile lovable_tanstack_start, ou edite +context.json manualmente." >&2
          exit 1
        fi
        pass_lovable=0
        if [[ -f package-lock.json ]]; then
          echo "FAIL: package-lock.json presente — causa raiz do Preview travado (Lovable é Bun-puro)" >&2
          echo "Fix: git rm package-lock.json && git commit -m 'chore(deps): remove package-lock.json (Lovable é bun-first)'" >&2
          pass_lovable=1
        else
          echo "ok: package-lock.json ausente"
        fi
        if [[ ! -f bun.lock ]]; then
          echo "FAIL: bun.lock ausente — rode 'bun install' para gerar" >&2
          pass_lovable=1
        else
          echo "ok: bun.lock presente"
        fi
        if ! command -v bun >/dev/null 2>&1; then
          echo "warn: bun não está no PATH local — agente não conseguirá rodar 'bun install' aqui"
        else
          echo "ok: bun no PATH ($(bun --version 2>/dev/null))"
        fi
        if [[ $pass_lovable -eq 0 ]]; then
          echo "PASS: lovable doctor"
        else
          exit 1
        fi
        ;;
      bootstrap)
        # Desliga "automatically delete head branches" no repo do GitHub.
        # Sem isso, mergear PRs Lovable pode deletar branches que a Lovable depende.
        if [[ "$_lovable_enabled" != "true" ]]; then
          echo "FAIL: +context.json não declara lovable_integration.enabled=true" >&2
          exit 1
        fi
        repo_name="$(_context_get repository.name)"
        if [[ -z "$repo_name" ]]; then
          echo "FAIL: +context.json não tem repository.name (esperado owner/repo)" >&2
          exit 1
        fi
        if ! command -v gh >/dev/null 2>&1; then
          echo "FAIL: gh CLI não está instalado (necessário para PATCH /repos/${repo_name})" >&2
          exit 1
        fi
        echo "== WSD Lovable Bootstrap =="
        echo "Desligando delete_branch_on_merge em ${repo_name}..."
        if gh api -X PATCH "/repos/${repo_name}" -f delete_branch_on_merge=false >/dev/null; then
          echo "ok: delete_branch_on_merge=false aplicado em ${repo_name}"
        else
          echo "FAIL: PATCH falhou — verifique autenticação gh e permissões no repo" >&2
          exit 1
        fi
        ;;
      help|*)
        cat <<USAGE
Usage: ./+wsd/bin/wsd lovable <subcommand>
  doctor     — verifica invariantes Lovable (package-lock.json ausente, bun.lock presente)
  bootstrap  — aplica configuração GitHub no repo (delete_branch_on_merge=false) via gh api
USAGE
        ;;
    esac
    ;;
  version)
    _wsd_version_report "$@"
    ;;
  help|--help|-h)
    echo "Usage: ./+wsd/bin/wsd start|check|finish|doctor|hooks|update|git|party|snapshot|version|lovable"
    echo "       ./+wsd/bin/wsd version [--inventory|--scan] [--json] [--path <dir>] [--max-depth <n>]"
    ;;
  *)
    echo "Unknown WSD command: $command" >&2
    echo "Usage: ./+wsd/bin/wsd start|check|finish|doctor|hooks|update|git|party|snapshot|version|lovable" >&2
    exit 1
    ;;
esac
