#!/usr/bin/env bash
set -euo pipefail

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
project_root="$(cd "$script_dir/../.." && pwd)"
command="${1:-help}"
shift || true

cd "$project_root"

_context_get() {
  local key_path="${1:-}"
  [[ -f +context.json ]] || return 0
  command -v python3 >/dev/null || return 0
  WSD_KEY_PATH="$key_path" python3 - <<'PY' 2>/dev/null || true
import json
import os

path = os.environ.get("WSD_KEY_PATH", "")
with open("+context.json", encoding="utf-8") as fh:
    data = json.load(fh)
cur = data
for part in path.split("."):
    if not part:
        continue
    if not isinstance(cur, dict) or part not in cur:
        raise SystemExit(0)
    cur = cur[part]
if isinstance(cur, bool):
    print("true" if cur else "false")
elif cur is None:
    print("")
else:
    print(cur)
PY
}

_git_mode() {
  local mode
  mode="$(_context_get git_governance.mode)"
  [[ -n "$mode" ]] || mode="none"
  printf "%s\n" "$mode"
}

_git_current_branch() {
  git rev-parse --abbrev-ref HEAD 2>/dev/null || true
}

_git_upstream() {
  git rev-parse --abbrev-ref --symbolic-full-name '@{u}' 2>/dev/null || true
}

_git_has_changes_for_pr() {
  local base_ref="$1"
  [[ -n "$base_ref" ]] || return 1
  git rev-list --count "${base_ref}..HEAD" 2>/dev/null | grep -qE '^[1-9][0-9]*$'
}

_git_base_ref() {
  local default_branch="$1"
  if [[ -n "$default_branch" ]] && git show-ref --verify --quiet "refs/remotes/origin/${default_branch}"; then
    printf "origin/%s\n" "$default_branch"
    return 0
  fi
  if [[ -n "$default_branch" ]] && git show-ref --verify --quiet "refs/heads/${default_branch}"; then
    printf "%s\n" "$default_branch"
    return 0
  fi
  printf "%s\n" "${default_branch:-main}"
}

_json_get() {
  local file="$1"
  local path="$2"
  [[ -f "$file" ]] || return 1

  node - "$file" "$path" <<'NODE' 2>/dev/null
const fs = require('fs');

const filePath = process.argv[2];
const keyPath = process.argv[3];

let data;
try {
  data = JSON.parse(fs.readFileSync(filePath, 'utf8'));
} catch (_error) {
  process.exit(1);
}

const keys = String(keyPath).split('.').filter(Boolean);
let value = data;
for (const key of keys) {
  if (!value || typeof value !== 'object' || !Object.prototype.hasOwnProperty.call(value, key)) {
    process.exit(1);
  }
  value = value[key];
}

if (value === undefined || value === null) {
  process.exit(1);
}

if (typeof value === 'string' || typeof value === 'number' || typeof value === 'boolean') {
  process.stdout.write(String(value));
} else {
  process.stdout.write(JSON.stringify(value));
}
NODE
}

_normalize_version() {
  local version="$1"
  version="${version#v}"
  printf "%s" "$version"
}

_version_cmp() {
  local a="$1"
  local b="$2"
  a="$(_normalize_version "$a")"
  b="$(_normalize_version "$b")"

  [[ -n "$a" && -n "$b" ]] || { echo "unknown"; return; }
  if [[ "$a" == "$b" ]]; then
    echo "eq"
    return
  fi
  if [[ "$(printf '%s\n%s\n' "$a" "$b" | sort -V | head -n 1)" == "$a" ]]; then
    echo "lt"
  else
    echo "gt"
  fi
}

_wsd_version_record() {
  local root="$1"
  local as_json="${2:-0}"
  local norm_root="${root%/}"

  local cfg_path="${norm_root}/+wsd/config.json"
  local project_path="${norm_root}/+context.json"
  local source_version_path
  local source_candidate_path
  local project_name
  local installed_version
  local installed_at
  local source_path
  local source_version="n/a"
  local status="not-installed"
  local source_match_raw="n/a"
  local cfg_exists=0
  local cmp

  project_name="$(_json_get "$project_path" "project.name" || true)"
  installed_version="$(_json_get "$cfg_path" "version" || true)"
  installed_at="$(_json_get "$cfg_path" "installed_at" || true)"
  source_path="$(_json_get "$cfg_path" "wsd_source" || true)"
  [[ -f "$cfg_path" ]] && cfg_exists=1

  if [[ -z "$project_name" ]]; then
    project_name="$(basename "$norm_root")"
  fi
  if [[ -z "$installed_version" ]]; then
    installed_version="n/a"
  fi
  if [[ -z "$installed_at" ]]; then
    installed_at="n/a"
  fi
  if [[ -n "$source_path" ]]; then
    if [[ "$source_path" = /* ]]; then
      source_version_path="$source_path/package.json"
    else
      source_candidate_path="${norm_root}/${source_path}/package.json"
      if [[ -f "$source_candidate_path" ]]; then
        source_version_path="$source_candidate_path"
      else
        source_version_path="${norm_root}/$source_path/package.json"
      fi
    fi
    if [[ -f "$source_version_path" ]]; then
      source_path="${source_version_path%/package.json}"
    fi
    source_version="$(_json_get "$source_version_path" "version" || true)"
    [[ -n "$source_version" ]] || source_version="n/a"
  else
    source_path="n/a"
  fi

  if [[ "$cfg_exists" -eq 1 && "$installed_version" == "n/a" ]]; then
    status="unreadable"
  elif [[ -z "${installed_version// /}" ]]; then
    status="unreadable"
  elif [[ "$installed_version" != "n/a" && "$source_version" != "n/a" ]]; then
    cmp="$(_version_cmp "$installed_version" "$source_version")"
    if [[ "$cmp" == "eq" ]]; then
      status="aligned"
      source_match_raw="true"
    elif [[ "$cmp" == "lt" ]]; then
      status="behind-source"
      source_match_raw="false"
    elif [[ "$cmp" == "gt" ]]; then
      status="ahead-of-source"
      source_match_raw="n/a"
    else
      status="unknown"
      source_match_raw="n/a"
    fi
  elif [[ -f "$cfg_path" ]]; then
    status="source-unknown"
  else
    status="not-installed"
  fi

  if [[ -z "$source_match_raw" ]]; then
    source_match_raw="n/a"
  fi

    if [[ "$as_json" == "1" ]]; then
      node - "$norm_root" "$project_name" "$installed_version" "$installed_at" "$source_path" "$source_version" "$status" "$source_match_raw" <<'NODE'
const [
  ,
  ,
  path,
  project,
  installed_version,
  installed_at,
  source_path,
  source_version,
  status,
  source_match
] = process.argv;
console.log(JSON.stringify({
  path,
  project,
  installed_version,
  installed_at,
  source_path,
  source_version,
  status,
  source_match,
}));
NODE
  else
      printf '%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\n' \
      "$norm_root" "$project_name" "$installed_version" "$installed_at" "$source_path" "$source_version" "$status" "$source_match_raw"
  fi
}

_wsd_version_report() {
  local as_json=0
  local inventory=0
  local -a roots=()
  local max_depth=4
  local arg

  while [[ "$#" -gt 0 ]]; do
    arg="$1"
    case "$arg" in
      --json)
        as_json=1
        shift
        ;;
      --inventory|--scan)
        inventory=1
        shift
        ;;
      --root|--path)
        [[ -n "${2-}" ]] || { echo "FAIL: --root precisa de valor" >&2; exit 1; }
        roots+=("$2")
        shift 2
        ;;
      --max-depth)
        [[ -n "${2-}" ]] || { echo "FAIL: --max-depth precisa de valor" >&2; exit 1; }
        max_depth="$2"
        shift 2
        ;;
      --help|-h)
        cat <<USAGE
Usage: ./+wsd/bin/wsd version [options]
  --json             saída JSON
  --inventory        varrer diretórios buscando projetos com +wsd/config.json
  --scan             sinônimo de --inventory
  --path <dir>       diretório para varredura (pode repetir)
  --max-depth <n>    profundidade máxima do find em inventory mode (padrão: 4)
  --help, -h         ajuda

Sem flags, consulta WSD apenas no diretório atual.
Exemplos:
  ./+wsd/bin/wsd version
  ./+wsd/bin/wsd version --inventory --path .
  ./+wsd/bin/wsd version --json --inventory --path ~/projects
USAGE
        return 0
        ;;
      *)
        echo "FAIL: argumento desconhecido em version: $arg" >&2
        echo "Hint: use ./+wsd/bin/wsd version --help" >&2
        return 1
        ;;
    esac
  done

  if (( inventory == 1 )); then
    local -a project_roots=()
    local -A seen=()
    local root

    if [[ ${#roots[@]} -eq 0 ]]; then
      roots+=(".")
    fi

    for root in "${roots[@]}"; do
      if [[ -f "$root/+wsd/config.json" ]]; then
        [[ -z "${seen[$root]-}" ]] && { seen["$root"]=1; project_roots+=("$root"); }
        continue
      fi

      if [[ ! -d "$root" ]]; then
        echo "WARN: diretório não encontrado em inventory mode: $root" >&2
        continue
      fi

      while IFS= read -r -d '' cfg_path; do
        local candidate="${cfg_path%/+wsd/config.json}"
        [[ -z "${seen[$candidate]-}" ]] && { seen["$candidate"]=1; project_roots+=("$candidate"); }
      done < <(find "$root" -maxdepth "$max_depth" -type f -path "*/+wsd/config.json" -print0)
    done

    if [[ ${#project_roots[@]} -eq 0 ]]; then
      echo "FAIL: nenhum +wsd/config.json encontrado em: ${roots[*]}" >&2
      return 1
    fi

    readarray -t project_roots < <(printf '%s\n' "${project_roots[@]}" | sort -u)

    if [[ "$as_json" == "1" ]]; then
      local root_path
      local first_record=1
      echo '['
      for root_path in "${project_roots[@]}"; do
        [[ -f "$root_path/+wsd/config.json" ]] || continue
        if [[ $first_record -eq 0 ]]; then
          echo ','
        fi
        printf '  '
        _wsd_version_record "$root_path" 1
        first_record=0
      done
      echo ']'
    else
      printf 'PATH\tPROJETO\tVERSION\tINSTALLED_AT\tSOURCE_PATH\tSOURCE_VERSION\tSTATUS\tSOURCE_MATCH\n'
      local path
      for path in "${project_roots[@]}"; do
        [[ -f "$path/+wsd/config.json" ]] || continue
        _wsd_version_record "$path" 0
      done
    fi
  else
    _wsd_version_record "." "$as_json"
  fi
}

_loop_usage() {
  cat <<USAGE
Usage: ./+wsd/bin/wsd loop <subcommand> [options]
  plan --feature <slug> [--agent-cmd <cmd>] [--allow-dirty]
  once --feature <slug> [--agent-cmd <cmd>] [--skip-ci] [--no-commit] [--human-approved]
  run  --feature <slug> --agent-cmd <cmd> [--max-iterations <n>] [--skip-ci] [--no-commit]
  auto status|on|off
  status
  stop

Options:
  --feature <slug>       feature directory under +specs/features/
  --agent-cmd <cmd>      command that reads WSD_LOOP_PROMPT and performs the agent step
  --max-iterations <n>   cap for run mode; defaults to automation.loop.default_max_iterations
  --dry-run              create the prompt and state only
  --skip-ci              skip ci.* commands from +context.json after the WSD gates
  --no-commit            do not auto-commit even when automation.loop.auto_commit=true
  --human-approved       allow an L2 loop run when automation.loop.require_human_for_l2=true
  --allow-dirty          bypass the clean-worktree preflight

Auto-use:
  loop auto on            sets automation.loop.auto_use=true in +context.json
  loop auto off           sets automation.loop.auto_use=false in +context.json
  loop auto status        shows current auto-use policy
USAGE
}

_loop_context_value() {
  local key="$1"
  local default_value="${2:-}"
  local value
  value="$(_json_get +context.json "$key" || true)"
  if [[ -n "$value" ]]; then
    printf "%s" "$value"
  else
    printf "%s" "$default_value"
  fi
}

_loop_fail() {
  echo "FAIL: $*" >&2
  return 1
}

_loop_auto_use_value() {
  _loop_context_value automation.loop.auto_use false
}

_loop_auto_use_status() {
  local value
  value="$(_loop_auto_use_value)"
  echo "automation.loop.auto_use=${value}"
  if [[ "$value" == "true" ]]; then
    echo "WSD Loop auto-use: enabled for eligible L0/L1 work when AGENTS.md/codex-prompt are followed"
  else
    echo "WSD Loop auto-use: disabled; loop runs only when explicitly requested"
  fi
}

_loop_set_auto_use() {
  local value="$1"
  [[ -f +context.json ]] || { _loop_fail "+context.json nao encontrado"; return 1; }
  command -v node >/dev/null 2>&1 || { _loop_fail "node nao encontrado"; return 1; }
  node - "$value" <<'NODE'
const fs = require('fs');
const value = process.argv[2] === 'true';
const file = '+context.json';
const ctx = JSON.parse(fs.readFileSync(file, 'utf8'));
ctx.automation = ctx.automation || {};
ctx.automation.loop = ctx.automation.loop || {};
ctx.automation.loop.auto_use = value;
fs.writeFileSync(file, JSON.stringify(ctx, null, 2) + '\n');
NODE
  echo "PASS: automation.loop.auto_use=${value}"
}

_loop_feature_spec() {
  local feature="$1"
  local spec="+specs/features/${feature}/spec.md"
  [[ -n "$feature" ]] || { _loop_fail "--feature e obrigatorio"; return 1; }
  [[ -f "$spec" ]] || { _loop_fail "spec nao encontrada: $spec"; return 1; }
  printf "%s" "$spec"
}

_loop_feature_tasks() {
  local feature="$1"
  printf "+specs/features/%s/tasks.md" "$feature"
}

_loop_feature_risk() {
  local spec="$1"
  local risk
  risk="$(grep -im1 -E '^(risk|severity):' "$spec" 2>/dev/null | sed -E 's/^[^:]+:[[:space:]]*"?([^"#[:space:]]+).*/\1/' | tr '[:lower:]' '[:upper:]' || true)"
  case "$risk" in
    L0|L1|L2) printf "%s" "$risk" ;;
    *) printf "L1" ;;
  esac
}

_loop_risk_allowed() {
  local risk="$1"
  node - "$risk" <<'NODE'
const fs = require('fs');
const risk = process.argv[2];
let ctx = {};
try {
  ctx = JSON.parse(fs.readFileSync('+context.json', 'utf8'));
} catch (_error) {
  process.exit(1);
}
const allowed = (((ctx.automation || {}).loop || {}).allowed_risks) || ['L0', 'L1'];
process.exit(allowed.includes(risk) ? 0 : 1);
NODE
}

_loop_check_risk() {
  local risk="$1"
  local human_approved="$2"
  local require_human_for_l2

  if ! _loop_risk_allowed "$risk"; then
    _loop_fail "risk $risk nao esta em automation.loop.allowed_risks"
    return 1
  fi

  require_human_for_l2="$(_loop_context_value automation.loop.require_human_for_l2 true)"
  if [[ "$risk" == "L2" && "$require_human_for_l2" == "true" && "$human_approved" != "1" ]]; then
    _loop_fail "risk L2 exige --human-approved"
    return 1
  fi
}

_loop_preflight() {
  local allow_dirty="$1"
  local enabled
  local require_clean

  command -v git >/dev/null 2>&1 || { _loop_fail "git nao encontrado"; return 1; }
  command -v node >/dev/null 2>&1 || { _loop_fail "node nao encontrado"; return 1; }
  git rev-parse --is-inside-work-tree >/dev/null 2>&1 || { _loop_fail "nao e um repositorio Git"; return 1; }
  [[ -f +context.json ]] || { _loop_fail "+context.json nao encontrado"; return 1; }
  [[ -f scripts/wsd_check.sh ]] || { _loop_fail "scripts/wsd_check.sh nao encontrado"; return 1; }

  enabled="$(_loop_context_value automation.loop.enabled true)"
  [[ "$enabled" != "false" ]] || { _loop_fail "automation.loop.enabled=false"; return 1; }

  require_clean="$(_loop_context_value automation.loop.require_clean_worktree true)"
  if [[ "$allow_dirty" != "1" && "$require_clean" == "true" && -n "$(git status --porcelain)" ]]; then
    git status --short >&2
    _loop_fail "worktree suja; commit/stash antes do loop ou use --allow-dirty conscientemente"
    return 1
  fi
}

_loop_acquire_lock() {
  mkdir -p +wsd/loop
  if [[ -f +wsd/loop/lock ]]; then
    _loop_fail "loop lock ativo em +wsd/loop/lock"
    return 1
  fi
  printf "%s\n" "$$" > +wsd/loop/lock
  trap '_loop_release_lock' EXIT
}

_loop_release_lock() {
  rm -f +wsd/loop/lock
  trap - EXIT
}

_loop_write_state() {
  local mode="$1"
  local feature="$2"
  local status="$3"
  local prompt="$4"
  local iteration="${5:-0}"
  local message="${6:-}"
  mkdir -p +wsd/loop
  node - "$mode" "$feature" "$status" "$prompt" "$iteration" "$message" > +wsd/loop/state.json <<'NODE'
const [mode, feature, status, prompt, iteration, message] = process.argv.slice(2);
const state = {
  schema: 'wsd/loop-state/v1',
  updated_at: new Date().toISOString(),
  mode,
  feature,
  status,
  prompt,
  iteration: Number(iteration || 0),
  message,
};
process.stdout.write(JSON.stringify(state, null, 2) + '\n');
NODE
}

_loop_make_prompt() {
  local mode="$1"
  local feature="$2"
  local risk="$3"
  local spec="$4"
  local tasks="$5"
  local iteration="${6:-0}"
  local run_id
  local log_dir
  local prompt_file
  local template

  run_id="$(date '+%Y%m%d-%H%M%S')-$$"
  log_dir="+logs/wsd-loop/${run_id}"
  prompt_file="${log_dir}/prompt-${mode}.md"
  template="+wsd/loop/PROMPT_${mode}.md"
  [[ "$mode" == "build" ]] && template="+wsd/loop/PROMPT_build.md"

  mkdir -p "$log_dir"
  {
    printf "# WSD Loop %s\n\n" "$mode"
    printf -- "- feature: %s\n" "$feature"
    printf -- "- risk: %s\n" "$risk"
    printf -- "- spec: %s\n" "$spec"
    printf -- "- tasks: %s\n" "$tasks"
    printf -- "- iteration: %s\n\n" "$iteration"
    printf "## Runtime Contract\n\n"
    printf "Use these environment variables if an agent command is provided:\n\n"
    printf -- "- WSD_LOOP_PROMPT: this prompt file\n"
    printf -- "- WSD_LOOP_FEATURE: %s\n" "$feature"
    printf -- "- WSD_LOOP_MODE: %s\n" "$mode"
    printf -- "- WSD_LOOP_RISK: %s\n\n" "$risk"
    printf "## Base Instructions\n\n"
    if [[ -f "$template" ]]; then
      cat "$template"
    else
      printf "Follow AGENTS.md, +context.json and the target spec.\n"
    fi
  } > "$prompt_file"

  printf "%s" "$prompt_file"
}

_loop_validate_changed_paths() {
  node <<'NODE'
const fs = require('fs');
const cp = require('child_process');

let ctx = {};
try {
  ctx = JSON.parse(fs.readFileSync('+context.json', 'utf8'));
} catch (error) {
  console.error('FAIL: cannot read +context.json');
  process.exit(1);
}

function norm(path) {
  return String(path || '')
    .replace(/\\/g, '/')
    .replace(/^\.\//, '')
    .replace(/\/+$/, '') || '.';
}

function within(file, root) {
  if (root === '.') return true;
  return file === root || file.startsWith(root + '/');
}

const permissions = ctx.permissions || {};
const writePaths = (permissions.write_paths || []).map(norm);
const forbiddenPaths = (permissions.forbidden_paths || []).map(norm);
const raw = cp.execFileSync('git', ['status', '--porcelain=v1', '-z'], { encoding: 'buffer' }).toString('utf8');
const parts = raw.split('\0').filter(Boolean);
const files = [];

for (let i = 0; i < parts.length; i += 1) {
  const entry = parts[i];
  const status = entry.slice(0, 2);
  const file = norm(entry.slice(3));
  files.push(file);
  if (status[0] === 'R' || status[0] === 'C') i += 1;
}

const violations = files.filter((file) => {
  if (forbiddenPaths.some((root) => within(file, root))) return true;
  if (writePaths.length > 0 && !writePaths.some((root) => within(file, root))) return true;
  return false;
});

if (violations.length > 0) {
  console.error('FAIL: changed paths outside +context.json permissions:');
  for (const file of violations) console.error(`  - ${file}`);
  process.exit(1);
}
NODE
}

_loop_ci_commands() {
  node <<'NODE'
const fs = require('fs');
let ctx = {};
try {
  ctx = JSON.parse(fs.readFileSync('+context.json', 'utf8'));
} catch (_error) {
  process.exit(0);
}
const ci = ctx.ci || {};
const commands = []
  .concat(ci.lint_commands || [])
  .concat(ci.test_commands || [])
  .concat(ci.build_commands || []);
for (const command of commands) {
  if (typeof command === 'string' && command.trim()) console.log(command.trim());
}
NODE
}

_loop_run_wsd_gates() {
  local risk="$1"
  local spec="$2"

  bash scripts/wsd_check.sh --risk L0 .
  if [[ "$risk" == "L1" || "$risk" == "L2" ]]; then
    bash scripts/wsd_check.sh --risk "$risk" --spec "$spec" .
  fi
}

_loop_run_ci_gates() {
  local skip_ci="$1"
  local cmd

  [[ "$skip_ci" != "1" ]] || { echo "info: ci gates skipped by --skip-ci"; return 0; }
  while IFS= read -r cmd; do
    [[ -n "$cmd" ]] || continue
    echo "== ci: $cmd"
    bash -lc "$cmd"
  done < <(_loop_ci_commands)
}

_loop_auto_commit_if_needed() {
  local feature="$1"
  local iteration="$2"
  local no_commit="$3"
  local auto_commit

  [[ -n "$(git status --porcelain)" ]] || return 0

  auto_commit="$(_loop_context_value automation.loop.auto_commit true)"
  if [[ "$no_commit" == "1" || "$auto_commit" != "true" ]]; then
    echo "info: changes left uncommitted"
    return 0
  fi

  git add -A
  git commit -m "chore(wsd-loop): ${feature} iteration ${iteration}"

  if [[ "$(_loop_context_value automation.loop.auto_push false)" == "true" ]]; then
    git push
  fi
}

_loop_plan() {
  local feature="$1"
  local agent_cmd="$2"
  local dry_run="$3"
  local human_approved="$4"
  local allow_dirty="$5"
  local spec
  local tasks
  local risk
  local prompt_file

  _loop_preflight "$allow_dirty"
  spec="$(_loop_feature_spec "$feature")"
  tasks="$(_loop_feature_tasks "$feature")"
  risk="$(_loop_feature_risk "$spec")"
  _loop_check_risk "$risk" "$human_approved"
  prompt_file="$(_loop_make_prompt plan "$feature" "$risk" "$spec" "$tasks" 0)"
  _loop_write_state plan "$feature" "prompt-ready" "$prompt_file" 0 "plan prompt ready"

  if [[ "$dry_run" == "1" || -z "$agent_cmd" ]]; then
    echo "prompt: $prompt_file"
    echo "PASS: WSD loop plan prompt ready"
    return 0
  fi

  _loop_acquire_lock
  WSD_LOOP_PROMPT="$prompt_file" WSD_LOOP_FEATURE="$feature" WSD_LOOP_MODE="plan" WSD_LOOP_RISK="$risk" bash -lc "$agent_cmd"
  _loop_release_lock
  _loop_write_state plan "$feature" "completed" "$prompt_file" 0 "plan agent completed"
  echo "PASS: WSD loop plan completed"
}

_loop_once() {
  local feature="$1"
  local agent_cmd="$2"
  local iteration="$3"
  local dry_run="$4"
  local skip_ci="$5"
  local no_commit="$6"
  local human_approved="$7"
  local allow_dirty="$8"
  local spec
  local tasks
  local risk
  local prompt_file

  _loop_preflight "$allow_dirty"
  spec="$(_loop_feature_spec "$feature")"
  tasks="$(_loop_feature_tasks "$feature")"
  [[ -f "$tasks" ]] || { _loop_fail "tasks nao encontrado: $tasks; rode wsd loop plan primeiro"; return 1; }
  risk="$(_loop_feature_risk "$spec")"
  _loop_check_risk "$risk" "$human_approved"
  prompt_file="$(_loop_make_prompt build "$feature" "$risk" "$spec" "$tasks" "$iteration")"
  _loop_write_state build "$feature" "prompt-ready" "$prompt_file" "$iteration" "build prompt ready"

  if [[ "$dry_run" == "1" || -z "$agent_cmd" ]]; then
    echo "prompt: $prompt_file"
    echo "PASS: WSD loop build prompt ready"
    return 0
  fi

  _loop_acquire_lock
  WSD_LOOP_PROMPT="$prompt_file" WSD_LOOP_FEATURE="$feature" WSD_LOOP_MODE="build" WSD_LOOP_RISK="$risk" bash -lc "$agent_cmd"
  _loop_validate_changed_paths
  git diff --check
  _loop_run_wsd_gates "$risk" "$spec"
  _loop_run_ci_gates "$skip_ci"
  _loop_auto_commit_if_needed "$feature" "$iteration" "$no_commit"
  _loop_release_lock
  _loop_write_state build "$feature" "completed" "$prompt_file" "$iteration" "iteration completed"
  echo "PASS: WSD loop iteration completed"
}

_wsd_loop() {
  local subcommand="${1:-help}"
  shift || true

  local feature=""
  local agent_cmd=""
  local max_iterations=""
  local dry_run=0
  local skip_ci=0
  local no_commit=0
  local human_approved=0
  local allow_dirty=0
  local arg

  case "$subcommand" in
    help|--help|-h)
      _loop_usage
      return 0
      ;;
    status)
      if [[ -f +wsd/loop/state.json ]]; then
        cat +wsd/loop/state.json
      else
        echo "WSD Loop: no state"
      fi
      return 0
      ;;
    stop)
      mkdir -p +wsd/loop
      rm -f +wsd/loop/lock
      _loop_write_state stop "" "stopped" "" 0 "stopped by operator"
      echo "PASS: WSD loop stopped"
      return 0
      ;;
    auto)
      local action="${1:-status}"
      case "$action" in
        status)
          _loop_auto_use_status
          ;;
        on|enable|enabled|true)
          _loop_set_auto_use true
          ;;
        off|disable|disabled|false)
          _loop_set_auto_use false
          ;;
        help|--help|-h)
          echo "Usage: ./+wsd/bin/wsd loop auto status|on|off"
          ;;
        *)
          echo "FAIL: argumento desconhecido em loop auto: $action" >&2
          echo "Usage: ./+wsd/bin/wsd loop auto status|on|off" >&2
          return 1
          ;;
      esac
      return
      ;;
    plan|once|run)
      ;;
    *)
      echo "Unknown WSD loop command: $subcommand" >&2
      _loop_usage >&2
      return 1
      ;;
  esac

  while [[ "$#" -gt 0 ]]; do
    arg="$1"
    case "$arg" in
      --feature)
        [[ -n "${2-}" ]] || { _loop_fail "--feature precisa de valor"; return 1; }
        feature="$2"
        shift 2
        ;;
      --agent-cmd)
        [[ -n "${2-}" ]] || { _loop_fail "--agent-cmd precisa de valor"; return 1; }
        agent_cmd="$2"
        shift 2
        ;;
      --max-iterations)
        [[ -n "${2-}" ]] || { _loop_fail "--max-iterations precisa de valor"; return 1; }
        max_iterations="$2"
        shift 2
        ;;
      --dry-run)
        dry_run=1
        shift
        ;;
      --skip-ci)
        skip_ci=1
        shift
        ;;
      --no-commit)
        no_commit=1
        shift
        ;;
      --human-approved)
        human_approved=1
        shift
        ;;
      --allow-dirty)
        allow_dirty=1
        shift
        ;;
      --help|-h)
        _loop_usage
        return 0
        ;;
      *)
        echo "FAIL: argumento desconhecido em loop: $arg" >&2
        _loop_usage >&2
        return 1
        ;;
    esac
  done

  case "$subcommand" in
    plan)
      _loop_plan "$feature" "$agent_cmd" "$dry_run" "$human_approved" "$allow_dirty"
      ;;
    once)
      _loop_once "$feature" "$agent_cmd" 1 "$dry_run" "$skip_ci" "$no_commit" "$human_approved" "$allow_dirty"
      ;;
    run)
      [[ -n "$agent_cmd" ]] || { _loop_fail "loop run exige --agent-cmd"; return 1; }
      [[ -n "$max_iterations" ]] || max_iterations="$(_loop_context_value automation.loop.default_max_iterations 3)"
      [[ "$max_iterations" =~ ^[1-9][0-9]*$ ]] || { _loop_fail "--max-iterations deve ser inteiro positivo"; return 1; }
      local i
      for ((i = 1; i <= max_iterations; i += 1)); do
        echo "== WSD Loop iteration $i/$max_iterations =="
        _loop_once "$feature" "$agent_cmd" "$i" "$dry_run" "$skip_ci" "$no_commit" "$human_approved" "$allow_dirty"
      done
      echo "PASS: WSD loop run completed"
      ;;
  esac
}

_codex_usage() {
  cat <<'USAGE'
Usage:
  ./+wsd/bin/wsd codex-prompt [--mode start|execute|plan|loop] [--feature <slug>] [--task <text>] [--brief] [text...]
  ./+wsd/bin/wsd codex [--exec] [--dry-run] [--mode start|execute|plan|loop] [--feature <slug>] [--task <text>] [text...]

Purpose:
  Gera ou executa um prompt curto para Codex seguir WSDD sem o operador listar arquivos manualmente.

Examples:
  ./+wsd/bin/wsd codex-prompt --task "planeje e implemente login"
  ./+wsd/bin/wsd codex --task "corrija o bug do checkout"
  ./+wsd/bin/wsd codex --exec --feature checkout-loop
USAGE
}

_codex_parse_args() {
  _codex_mode="execute"
  _codex_feature=""
  _codex_task=""
  _codex_brief=0
  _codex_exec=0
  _codex_dry_run=0

  while [[ "$#" -gt 0 ]]; do
    case "$1" in
      --mode)
        [[ -n "${2:-}" ]] || { echo "FAIL: --mode precisa de valor" >&2; return 1; }
        _codex_mode="$2"
        shift 2
        ;;
      --feature)
        [[ -n "${2:-}" ]] || { echo "FAIL: --feature precisa de valor" >&2; return 1; }
        _codex_feature="$2"
        shift 2
        ;;
      --task)
        [[ -n "${2:-}" ]] || { echo "FAIL: --task precisa de valor" >&2; return 1; }
        _codex_task="${_codex_task}${_codex_task:+ }$2"
        shift 2
        ;;
      --brief)
        _codex_brief=1
        shift
        ;;
      --exec)
        _codex_exec=1
        shift
        ;;
      --dry-run)
        _codex_dry_run=1
        shift
        ;;
      help|--help|-h)
        _codex_usage
        return 2
        ;;
      --)
        shift
        if [[ "$#" -gt 0 ]]; then
          _codex_task="${_codex_task}${_codex_task:+ }$*"
        fi
        break
        ;;
      --*)
        echo "FAIL: argumento desconhecido para codex: $1" >&2
        _codex_usage >&2
        return 1
        ;;
      *)
        _codex_task="${_codex_task}${_codex_task:+ }$1"
        shift
        ;;
    esac
  done

  case "$_codex_mode" in
    start|execute|plan|loop) ;;
    *)
      echo "FAIL: --mode deve ser start, execute, plan ou loop" >&2
      return 1
      ;;
  esac
}

_codex_make_prompt() {
  local mode="$1"
  local feature="$2"
  local task="$3"
  local brief="$4"
  local auto_use
  local auto_use_hint

  auto_use="$(_loop_auto_use_value)"
  if [[ "$auto_use" == "true" ]]; then
    auto_use_hint="automation.loop.auto_use=true. Para tarefa L0/L1 elegivel, com spec aprovada e worktree limpa, use WSD Loop automaticamente: rode ./+wsd/bin/wsd loop plan --feature <slug> quando precisar planejar, e ./+wsd/bin/wsd loop once --feature <slug> para gerar o prompt de iteracao antes de executar. Se este comando foi chamado com --exec e --feature, o launcher pode usar loop run com Codex exec."
  else
    auto_use_hint="automation.loop.auto_use=false. Use WSD Loop apenas quando o operador pedir ou quando voce propuser explicitamente."
  fi

  if [[ "$brief" == "1" ]]; then
    cat <<PROMPT
Use WSDD neste repositorio. Siga AGENTS.md, leia +context.json e +specs/project/STATE.md, classifique risco L0/L1/L2, use spec/tasks quando necessario, edite apenas paths permitidos e valide antes de finalizar.
${auto_use_hint}
Modo: ${mode}
Feature: ${feature:-n/a}
Tarefa: ${task:-ler o projeto, diagnosticar estado WSD e propor proximo passo seguro}
PROMPT
    return
  fi

  cat <<PROMPT
Use WSDD neste repositorio.

Bootstrap obrigatorio:
- Siga AGENTS.md. O Codex normalmente carrega AGENTS.md ao iniciar na pasta; trate-o como contrato ativo.
- Antes de editar, leia +context.json e respeite permissions.write_paths, permissions.forbidden_paths e secrets_policy.
- Consulte +specs/project/STATE.md. Se +specs/HANDOFF.md existir, considere a continuidade da sessao anterior.
- Se existir, rode ./+wsd/bin/wsd start --brief para obter estado operacional compacto.
- Classifique a tarefa como L0, L1 ou L2 antes de executar.
- L1/L2 exigem spec aprovada em +specs/features/<slug>/spec.md; L2 exige aprovacao humana explicita e plano de rollback.
- Politica Ralph/WSD Loop: ${auto_use_hint}
- Para ideias fora do escopo, registre em +specs/project/STATE.md ou +specs/project/IDEAS.md em vez de implementar.
- Antes de finalizar mudancas relevantes, rode git diff --check e ./+wsd/bin/wsd check ou bash scripts/wsd_check.sh --risk L0 .
- Nunca use git add ., reset, clean, stash, merge, rebase, pull ou troca de branch para esconder estado local sem instrucao explicita. Excecao: ./+wsd/bin/wsd finish pode fazer staging/commit automatico depois dos gates.

Modo solicitado: ${mode}
Feature alvo: ${feature:-n/a}

Tarefa:
${task:-Ler o projeto, diagnosticar estado WSD e propor o proximo passo seguro.}

Resposta esperada:
- estado inicial relevante;
- risco classificado;
- arquivos/specs usados;
- alteracoes feitas ou plano proposto;
- validacoes executadas e resultado.
PROMPT
}

_wsd_codex_prompt() {
  _codex_parse_args "$@" || {
    local status=$?
    [[ "$status" -eq 2 ]] && return 0
    return "$status"
  }
  _codex_make_prompt "$_codex_mode" "$_codex_feature" "$_codex_task" "$_codex_brief"
}

_wsd_codex() {
  local prompt
  local auto_use
  local agent_cmd

  _codex_parse_args "$@" || {
    local status=$?
    [[ "$status" -eq 2 ]] && return 0
    return "$status"
  }

  prompt="$(_codex_make_prompt "$_codex_mode" "$_codex_feature" "$_codex_task" "$_codex_brief")"

  if [[ "$_codex_dry_run" == "1" ]]; then
    printf "%s\n" "$prompt"
    return 0
  fi

  command -v codex >/dev/null 2>&1 || {
    echo "FAIL: codex CLI nao encontrado no PATH" >&2
    echo "Use './+wsd/bin/wsd codex-prompt ...' e cole o prompt manualmente." >&2
    return 1
  }

  auto_use="$(_loop_auto_use_value)"
  if [[ "$auto_use" == "true" && "$_codex_exec" == "1" && -n "$_codex_feature" ]]; then
    echo "== WSD Codex Auto Loop =="
    echo "automation.loop.auto_use=true; executando WSD Loop para feature ${_codex_feature}"
    agent_cmd='codex exec -C "$PWD" "$(cat "$WSD_LOOP_PROMPT")"'
    _wsd_loop run --feature "$_codex_feature" --agent-cmd "$agent_cmd"
    return
  fi

  if [[ "$_codex_exec" == "1" ]]; then
    codex exec -C "$project_root" "$prompt"
  else
    codex --cd "$project_root" "$prompt"
  fi
}

_codex_shortcuts_usage() {
  cat <<'USAGE'
Usage: ./+wsd/bin/wsd codex-shortcuts <status|install|uninstall|print> [--force]

Purpose:
  Gerencia prompts globais opcionais do Codex para atalhos WSD.

Notes:
  Codex CLI usa prompts customizados como /prompts:<nome>. Para WSD Loop,
  o atalho opcional fica como /prompts:loop status, nao como /loop status.
  Para workflow compartilhado no repo, prefira a skill wsd-loop em .agents/skills.
USAGE
}

_codex_shortcuts_prompt_content() {
  if [[ -f +wsd/templates/codex-prompts/loop.md ]]; then
    cat +wsd/templates/codex-prompts/loop.md
    return
  fi

  cat <<'PROMPT'
---
description: WSD Codex Loop Shortcut: status, auto on/off, plan, once, run
argument-hint: "status | auto status|on|off | on | off | plan FEATURE | once FEATURE | run FEATURE"
---

# WSD Codex Loop Shortcut

Use WSDD in this repository and interpret `$ARGUMENTS` as a short WSD Loop request.

Valid mappings:

- `status` -> run `./+wsd/bin/wsd loop status`
- `auto status` -> run `./+wsd/bin/wsd loop auto status`
- `auto on` or `on` -> run `./+wsd/bin/wsd loop auto on`
- `auto off` or `off` -> run `./+wsd/bin/wsd loop auto off`
- `plan FEATURE` -> run `./+wsd/bin/wsd loop plan --feature FEATURE`
- `once FEATURE` -> run `./+wsd/bin/wsd loop once --feature FEATURE`
- `run FEATURE` -> only run after checking `+context.json`, approved spec, clean-worktree requirements, and L2 approval policy.

If `$ARGUMENTS` is empty, show current loop status and the available mappings.
PROMPT
}

_wsd_codex_shortcuts() {
  local action="${1:-status}"
  local force=0
  local codex_home="${CODEX_HOME:-$HOME/.codex}"
  local prompt_dir="$codex_home/prompts"
  local prompt_file="$prompt_dir/loop.md"

  shift || true
  while [[ "$#" -gt 0 ]]; do
    case "$1" in
      --force)
        force=1
        shift
        ;;
      help|--help|-h)
        _codex_shortcuts_usage
        return 0
        ;;
      *)
        echo "FAIL: argumento desconhecido para codex-shortcuts: $1" >&2
        _codex_shortcuts_usage >&2
        return 1
        ;;
    esac
  done

  case "$action" in
    status)
      echo "Codex skills repo-local:"
      if [[ -f .agents/skills/wsd-loop/SKILL.md ]]; then
        echo "ok: .agents/skills/wsd-loop/SKILL.md"
      elif [[ -f .codex/skills/wsd-loop/SKILL.md ]]; then
        echo "warn: .codex/skills/wsd-loop/SKILL.md presente; reinstale WSD para espelhar em .agents/skills"
      else
        echo "missing: wsd-loop skill"
      fi
      echo ""
      echo "Codex custom prompt opcional:"
      if [[ -f "$prompt_file" ]]; then
        echo "ok: $prompt_file"
      else
        echo "missing: $prompt_file"
      fi
      echo ""
      echo "Uso Codex recomendado:"
      echo "  loop status"
      echo "  loop auto on"
      echo "  loop auto off"
      echo "  /prompts:loop status   # apos: ./+wsd/bin/wsd codex-shortcuts install"
      ;;
    install)
      if [[ -f "$prompt_file" && "$force" != "1" ]] && ! grep -q 'WSD Codex Loop Shortcut' "$prompt_file"; then
        echo "FAIL: $prompt_file ja existe e nao parece ser prompt WSD. Use --force para sobrescrever." >&2
        return 1
      fi
      mkdir -p "$prompt_dir"
      _codex_shortcuts_prompt_content > "$prompt_file"
      echo "PASS: Codex prompt instalado em $prompt_file"
      echo "Reinicie o Codex CLI se o prompt nao aparecer."
      echo "Uso: /prompts:loop status"
      ;;
    uninstall)
      if [[ ! -f "$prompt_file" ]]; then
        echo "PASS: $prompt_file ja ausente"
      elif grep -q 'WSD Codex Loop Shortcut' "$prompt_file"; then
        rm -f "$prompt_file"
        echo "PASS: Codex prompt removido: $prompt_file"
      else
        echo "FAIL: $prompt_file existe e nao parece ser prompt WSD; remova manualmente se desejar." >&2
        return 1
      fi
      ;;
    print)
      _codex_shortcuts_prompt_content
      ;;
    help|--help|-h)
      _codex_shortcuts_usage
      ;;
    *)
      echo "FAIL: acao desconhecida para codex-shortcuts: $action" >&2
      _codex_shortcuts_usage >&2
      return 1
      ;;
  esac
}

_shortcuts_usage() {
  cat <<'USAGE'
Usage: ./+wsd/bin/wsd shortcuts <status|shell>

Purpose:
  Mostra atalhos curtos para evitar digitar ./+wsd/bin/wsd.

Examples:
  eval "$(./+wsd/bin/wsd shortcuts shell)"
  wsd loop auto status
  wl status
USAGE
}

_wsd_shortcuts() {
  local action="${1:-status}"
  case "$action" in
    status)
      echo "Atalhos disponiveis:"
      echo "  Codex: use a skill wsd-loop com pedidos como 'loop status' ou instale /prompts:loop via codex-shortcuts"
      echo "  Claude Code: use /loop status quando instalado com --tools claude-code"
      echo "  Shell: eval \"\$(./+wsd/bin/wsd shortcuts shell)\" e depois use 'wsd ...' ou 'wl ...'"
      ;;
    shell)
      cat <<'SHELL'
wsd() {
  local root
  root="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
  if [ -x "$root/+wsd/bin/wsd" ]; then
    (cd "$root" && ./+wsd/bin/wsd "$@")
  else
    printf '%s\n' "WSD not found from $PWD" >&2
    return 127
  fi
}
wl() {
  wsd loop "$@"
}
SHELL
      ;;
    help|--help|-h)
      _shortcuts_usage
      ;;
    *)
      echo "FAIL: acao desconhecida para shortcuts: $action" >&2
      _shortcuts_usage >&2
      return 1
      ;;
  esac
}

_finish_usage() {
  cat <<'USAGE'
Usage: ./+wsd/bin/wsd finish [options]

Purpose:
  Fecha a sessao WSD com gates, auditoria documental quando disponivel,
  HANDOFF.md, snapshot e commit automatico de fechamento.

Options:
  -m, --message <msg>   mensagem do commit de fechamento
  --skip-docs-check     pula auditoria documental WSD
  --no-commit           diagnostico: gera relatorio, mas nao fecha o worktree
  --help, -h            ajuda

Default:
  O finish commita as alteracoes aprovadas para terminar com git status limpo.
USAGE
}

_finish_docs_check() {
  if [[ -f scripts/wsd_docs_check.sh && -d docs ]]; then
    bash scripts/wsd_docs_check.sh
    return 0
  fi

  if [[ -f +wsd/scripts/wsd_docs_check.sh && -d +wsd/docs && -f +wsd/README.md && -f +wsd/package.json ]]; then
    (cd +wsd && bash scripts/wsd_docs_check.sh)
    return 0
  fi

  return 2
}

_finish_sensitive_dirty_check() {
  local status_text="${1:-}"
  local blocked

  blocked="$(printf "%s\n" "$status_text" | grep -E '(^|[[:space:]])(\.env($|[./])|.*[./](\.env|secrets?|keys?|certs?)(/|$)|.*[./](id_rsa|id_ed25519)(\.pub)?$)' || true)"
  if [[ -n "$blocked" ]]; then
    echo "FAIL: wsd finish encontrou paths sensiveis no estado Git; revise manualmente antes de aprovar commit." >&2
    printf "%s\n" "$blocked" >&2
    return 1
  fi
}

_finish_state_prompts() {
  local today="$1"

  [[ -f +specs/project/STATE.md ]] || return 0

  if ! command -v python3 >/dev/null; then
    echo "info: python3 ausente -- STATE.md prompts pulados; preencher manualmente"
    return 0
  fi
  if [[ ! -t 0 ]]; then
    echo "info: STATE.md prompts pulados (stdin nao-interativo)"
    return 0
  fi

  _state_insert() {
    WSD_FILE="$1" WSD_SECTION="$2" WSD_ROW="$3" python3 -c "
import os
f = os.environ['WSD_FILE']
sec = os.environ['WSD_SECTION']
row = os.environ['WSD_ROW']
lines = open(f).readlines()
out = []
in_sec = False
done = False
for l in lines:
    out.append(l)
    if sec in l:
        in_sec = True
    elif in_sec and not done and l.startswith('|---'):
        out.append(row + '\n')
        done = True
        in_sec = False
open(f, 'w').writelines(out)
"
  }

  echo ""
  echo "== Captura de Memoria Operacional =="

  printf "Houve licoes aprendidas nesta sessao? [s/N] "
  read -r _resp
  if [[ "$_resp" =~ ^[Ss]$ ]]; then
    printf "  Licao (1 linha): "
    read -r _licao
    if [[ -n "$_licao" ]]; then
      printf "  Como prevenir? (1 linha): "
      read -r _prevencao
      _state_insert "+specs/project/STATE.md" "Aprendidas" "| $today | $_licao | $_prevencao |"
      echo "  ok: licao registrada em STATE.md"
    fi
  fi

  printf "Houve decisoes arquiteturais ou de metodo? [s/N] "
  read -r _resp
  if [[ "$_resp" =~ ^[Ss]$ ]]; then
    printf "  Decisao (1 linha): "
    read -r _decisao
    if [[ -n "$_decisao" ]]; then
      printf "  Racional (1 linha): "
      read -r _racional
      _state_insert "+specs/project/STATE.md" "## Decis" "| $today | $_decisao | $_racional |"
      echo "  ok: decisao registrada em STATE.md"
    fi
  fi

  printf "Ha bloqueadores ativos? [s/N] "
  read -r _resp
  if [[ "$_resp" =~ ^[Ss]$ ]]; then
    printf "  Bloqueador (1 linha): "
    read -r _bloqueador
    if [[ -n "$_bloqueador" ]]; then
      printf "  Impacto (1 linha): "
      read -r _impacto
      _state_insert "+specs/project/STATE.md" "## Bloqueadores Ativos" "| $today | $_bloqueador | $_impacto | Em analise |"
      echo "  ok: bloqueador registrado em STATE.md"
    fi
  fi
}

_finish_write_handoff() {
  local status_before="$1"
  local gate_wsd="$2"
  local gate_docs="$3"
  local gate_pr="$4"
  local auto_commit="$5"
  local today now branch last_commit recent pending specs_list final_mode

  today="$(date '+%Y-%m-%d')"
  now="$(date '+%Y-%m-%d %H:%M')"
  branch="$(git rev-parse --abbrev-ref HEAD 2>/dev/null || echo 'unknown')"
  last_commit="$(git log -1 --pretty='%h - %s (%ad)' --date=short 2>/dev/null || echo '(no commits)')"
  recent="$(git log --oneline -5 2>/dev/null | sed 's/^/- /' || echo '- (none)')"
  specs_list="$(find +specs/features -maxdepth 2 -name 'spec.md' 2>/dev/null | sed 's/^/- /' || true)"
  [[ -n "$specs_list" ]] || specs_list="- (nenhuma)"

  if [[ -n "$status_before" ]]; then
    pending="$(printf "%s\n" "$status_before" | sed 's/^/- /')"
  else
    pending="- nenhuma alteracao pendente antes do fechamento"
  fi

  if [[ "$auto_commit" == "1" ]]; then
    final_mode="limpo apos commit automatico do wsd finish"
  else
    final_mode="nao garantido porque --no-commit foi usado"
  fi

  mkdir -p +specs
  {
    printf "# HANDOFF -- %s\n\n" "$now"
    printf "## Sessao\n\n"
    printf -- "- Branch: %s\n" "$branch"
    printf -- "- Ultimo commit antes do fechamento: %s\n" "$last_commit"
    if [[ -n "$status_before" ]]; then
      printf -- "- Estado antes do finish: alteracoes pendentes capturadas para fechamento\n"
    else
      printf -- "- Estado antes do finish: limpo\n"
    fi
    printf -- "- Estado final esperado: %s\n" "$final_mode"
    printf -- "- Data de fechamento: %s\n" "$today"

    printf "\n## Gates de Aprovacao\n\n"
    printf -- "- git diff --check: PASS\n"
    printf -- "- WSD check L0: %s\n" "$gate_wsd"
    printf -- "- WSD docs check: %s\n" "$gate_docs"
    printf -- "- PR status: %s\n" "$gate_pr"

    printf "\n## Concluido nesta sessao\n\n"
    printf "(ultimos 5 commits antes do fechamento)\n"
    printf "%s\n" "$recent"

    printf "\n## Alteracoes Capturadas Pelo Finish\n\n"
    printf "%s\n" "$pending"

    printf "\n## Proximos Passos\n\n"
    printf -- "- [ ] Abrir proxima sessao com ./+wsd/bin/wsd start --brief e confirmar estado limpo.\n"

    printf "\n## Referencias\n\n"
    printf -- "- STATE: +specs/project/STATE.md\n"
    printf -- "- CONCERNS: +specs/project/CONCERNS.md\n"
    printf -- "- CONCERNS_PIPELINE: +specs/project/CONCERNS_PIPELINE.md\n"
    printf -- "- Specs:\n"
    printf "%s\n" "$specs_list"
  } > "+specs/HANDOFF.md"
}

_relatorio_usage() {
  cat <<'USAGE'
Usage: ./+wsd/bin/wsd relatorio [options]

Purpose:
  Gera um relatorio geral WSD em Markdown com estado atual, implementacoes em
  andamento, plano programado, ideias, concerns e sugestao de proximo passo.

Options:
  --save                salva em +specs/RELATORIO.md
  --output <file>       salva em um caminho especifico
  --help, -h            ajuda

Aliases:
  report, status-report, resumo
USAGE
}

_wsd_relatorio() {
  local output=""

  while [[ "$#" -gt 0 ]]; do
    case "$1" in
      --save)
        output="+specs/RELATORIO.md"
        shift
        ;;
      --output)
        [[ -n "${2-}" ]] || { echo "FAIL: --output precisa de valor" >&2; return 1; }
        output="$2"
        shift 2
        ;;
      help|--help|-h)
        _relatorio_usage
        return 0
        ;;
      *)
        echo "FAIL: argumento desconhecido em relatorio: $1" >&2
        _relatorio_usage >&2
        return 1
        ;;
    esac
  done

  WSD_RELATORIO_OUTPUT="$output" node - <<'NODE'
const fs = require('fs');
const path = require('path');
const cp = require('child_process');

const root = process.cwd();
const outputPath = process.env.WSD_RELATORIO_OUTPUT || '';

function read(file) {
  try {
    return fs.readFileSync(path.join(root, file), 'utf8');
  } catch (_error) {
    return '';
  }
}

function readJson(file) {
  try {
    return JSON.parse(read(file));
  } catch (_error) {
    return {};
  }
}

function git(args, fallback = '') {
  try {
    return cp.execFileSync('git', args, { cwd: root, encoding: 'utf8', stdio: ['ignore', 'pipe', 'ignore'] }).trim();
  } catch (_error) {
    return fallback;
  }
}

function strip(value) {
  return String(value || '')
    .replace(/`/g, '')
    .replace(/\*\*/g, '')
    .replace(/\s+/g, ' ')
    .trim();
}

function section(markdown, heading) {
  const lines = markdown.split(/\r?\n/);
  const start = lines.findIndex((line) => line.trim() === heading);
  if (start === -1) return '';
  const out = [];
  for (let i = start + 1; i < lines.length; i += 1) {
    if (/^##\s+/.test(lines[i])) break;
    out.push(lines[i]);
  }
  return out.join('\n');
}

function parseTableRows(markdown) {
  return markdown
    .split(/\r?\n/)
    .map((line) => line.trim())
    .filter((line) => line.startsWith('|') && line.endsWith('|'))
    .filter((line) => !/^\|\s*-{2,}/.test(line))
    .filter((line) => !line.includes('---'))
    .map((line) => line.slice(1, -1).split('|').map((cell) => strip(cell)))
    .filter((cells) => cells.some((cell) => cell && cell !== '—'))
    .filter((cells) => !cells.some((cell) => cell.startsWith('_(')));
}

function tableRows(file, heading) {
  const markdown = read(file);
  if (!markdown) return [];
  return parseTableRows(section(markdown, heading));
}

function checkboxItems(file, heading) {
  const markdown = read(file);
  if (!markdown) return [];
  return section(markdown, heading)
    .split(/\r?\n/)
    .map((line) => line.trim())
    .filter((line) => /^- \[ \]/.test(line))
    .map((line) => strip(line.replace(/^- \[ \]\s*/, '')));
}

function frontmatter(file) {
  const content = read(file);
  if (!content.startsWith('---')) return {};
  const end = content.indexOf('\n---', 3);
  if (end === -1) return {};
  const data = {};
  content.slice(3, end).split(/\r?\n/).forEach((line) => {
    const match = line.match(/^([A-Za-z0-9_-]+):\s*(.*)$/);
    if (match) data[match[1]] = strip(match[2]).replace(/^["']|["']$/g, '');
  });
  return data;
}

function listSpecs() {
  const base = path.join(root, '+specs/features');
  if (!fs.existsSync(base)) return [];
  return fs.readdirSync(base, { withFileTypes: true })
    .filter((entry) => entry.isDirectory())
    .map((entry) => {
      const specPath = `+specs/features/${entry.name}/spec.md`;
      const tasksPath = `+specs/features/${entry.name}/tasks.md`;
      const meta = frontmatter(specPath);
      const tasks = read(tasksPath);
      const openTasks = (tasks.match(/^- \[ \]/gm) || []).length;
      return {
        slug: entry.name,
        title: meta.title || entry.name,
        status: strip(meta.status || 'unknown'),
        risk: strip(meta.risk || 'unknown'),
        specPath,
        tasksPath: fs.existsSync(path.join(root, tasksPath)) ? tasksPath : '',
        openTasks,
      };
    })
    .sort((a, b) => a.slug.localeCompare(b.slug));
}

function countIdeaIds() {
  const ideas = read('+specs/project/IDEAS.md');
  return [...ideas.matchAll(/^##\s+(IDEA-[0-9]+)/gm)].map((match) => match[1]);
}

function rowStatus(row, index) {
  return strip(row[index] || '').toLowerCase();
}

function isClosedStatus(status) {
  return ['done', 'resolved', 'accepted-risk', 'obsolete', 'implementada', 'descartada', 'discarded'].includes(status);
}

function bulletRows(rows, formatter, emptyText, limit = 10) {
  const visible = rows.slice(0, limit);
  if (!visible.length) return [`- ${emptyText}`];
  const out = visible.map(formatter);
  if (rows.length > limit) out.push(`- ... mais ${rows.length - limit} item(ns) omitido(s)`);
  return out;
}

function mdList(items, emptyText, limit = 10) {
  if (!items.length) return [`- ${emptyText}`];
  const out = items.slice(0, limit).map((item) => `- ${item}`);
  if (items.length > limit) out.push(`- ... mais ${items.length - limit} item(ns) omitido(s)`);
  return out;
}

const context = readJson('+context.json');
const wsdConfig = readJson('+wsd/config.json');
const projectName = context.project?.name || path.basename(root);
const projectType = context.project?.type || 'unknown';
const defaultBranch = context.repository?.default_branch || 'main';
const now = new Date();
const generatedAt = now.toISOString().replace('T', ' ').replace(/\..+$/, ' UTC');

const branch = git(['rev-parse', '--abbrev-ref', 'HEAD'], 'unknown');
const upstream = git(['rev-parse', '--abbrev-ref', '--symbolic-full-name', '@{u}'], 'missing');
const statusShort = git(['status', '--short', '--untracked-files=all'], '');
const lastCommit = git(['log', '-1', '--pretty=%h - %s (%ad)', '--date=short'], '(no commits)');
const remote = git(['remote', 'get-url', 'origin'], 'missing');
const aheadBehind = git(['status', '--short', '--branch'], '').split(/\r?\n/)[0] || 'unknown';

const roadmapActive = tableRows('+specs/project/ROADMAP.md', '## Features Ativas')
  .filter((row) => row[0] && row[0] !== 'Feature');
const roadmapBacklog = tableRows('+specs/project/ROADMAP.md', '## Backlog')
  .filter((row) => row[0] && row[0] !== 'Feature');
const roadmapDone = tableRows('+specs/project/ROADMAP.md', '## Concluídas')
  .filter((row) => row[0] && row[0] !== 'Feature');
const inProgressRoadmap = roadmapActive.filter((row) => rowStatus(row, 1) === 'in-progress');
const plannedRoadmap = roadmapActive.filter((row) => ['planned', 'specified', 'blocked'].includes(rowStatus(row, 1)));

const specs = listSpecs();
const openSpecs = specs.filter((spec) => !isClosedStatus(spec.status));
const specsWithOpenTasks = specs.filter((spec) => spec.openTasks > 0 && !isClosedStatus(spec.status));

const blockers = tableRows('+specs/project/STATE.md', '## Bloqueadores Ativos')
  .filter((row) => row[1] && row[1] !== 'Bloqueador' && !isClosedStatus(rowStatus(row, 3)));
const todos = checkboxItems('+specs/project/STATE.md', '## Todos Ativos');

const ideaIds = countIdeaIds();
const ideaPipeline = tableRows('+specs/project/IDEAS_PIPELINE.md', '## Pipeline')
  .filter((row) => /^IDEA-[0-9]+$/.test(row[0] || ''));
const activeIdeas = ideaPipeline.filter((row) => !isClosedStatus(rowStatus(row, 2)));
const ideaPipelineIds = new Set(ideaPipeline.map((row) => row[0]));
const ideasWithoutPipeline = ideaIds.filter((id) => !ideaPipelineIds.has(id));

const concernRows = tableRows('+specs/project/CONCERNS.md', '## Preocupacoes Ativas')
  .filter((row) => /^CONC-[0-9]+$/.test(row[0] || ''));
const activeConcerns = concernRows.filter((row) => !isClosedStatus(rowStatus(row, 4)));
const concernPipeline = tableRows('+specs/project/CONCERNS_PIPELINE.md', '## Pipeline')
  .filter((row) => /^CONC-[0-9]+$/.test(row[0] || ''));
const activeConcernPipeline = concernPipeline.filter((row) => !isClosedStatus(rowStatus(row, 2)));
const concernPipelineIds = new Set(concernPipeline.map((row) => row[0]));
const concernsWithoutPipeline = activeConcerns.map((row) => row[0]).filter((id) => !concernPipelineIds.has(id));

const docs = {
  context: fs.existsSync(path.join(root, '+context.json')),
  agents: fs.existsSync(path.join(root, 'AGENTS.md')),
  handoff: fs.existsSync(path.join(root, '+specs/HANDOFF.md')),
  roadmap: fs.existsSync(path.join(root, '+specs/project/ROADMAP.md')),
  ideas: fs.existsSync(path.join(root, '+specs/project/IDEAS.md')),
  ideasPipeline: fs.existsSync(path.join(root, '+specs/project/IDEAS_PIPELINE.md')),
  concerns: fs.existsSync(path.join(root, '+specs/project/CONCERNS.md')),
  concernsPipeline: fs.existsSync(path.join(root, '+specs/project/CONCERNS_PIPELINE.md')),
};

const attention = [];
if (statusShort) attention.push('worktree com alterações pendentes');
if (blockers.length) attention.push(`${blockers.length} bloqueador(es) ativo(s)`);
if (activeConcerns.length) attention.push(`${activeConcerns.length} concern(s) ativa(s)`);
if (concernsWithoutPipeline.length) attention.push(`${concernsWithoutPipeline.length} concern(s) sem pipeline`);
if (ideasWithoutPipeline.length) attention.push(`${ideasWithoutPipeline.length} ideia(s) sem pipeline`);
if (inProgressRoadmap.length || specsWithOpenTasks.length) attention.push('implementação em andamento detectada');
const overall = attention.length ? `atenção: ${attention.join('; ')}` : 'estável: sem sinais críticos nos artefatos WSD';

let suggestion;
if (statusShort) {
  suggestion = 'Finalizar ou registrar as alterações pendentes antes de iniciar nova frente. Se estiver tudo aprovado, rode `./+wsd/bin/wsd finish`.';
} else if (blockers.length) {
  suggestion = `Resolver ou reclassificar o bloqueador mais antigo: ${blockers[0][1]}.`;
} else if (concernsWithoutPipeline.length) {
  suggestion = `Criar plano no CONCERNS_PIPELINE.md para ${concernsWithoutPipeline[0]} antes de mexer em novas features.`;
} else if (activeConcernPipeline.length) {
  suggestion = `Avançar a concern ${activeConcernPipeline[0][0]} para o próximo passo: ${activeConcernPipeline[0][5] || activeConcernPipeline[0][4] || 'triagem/mitigação'}.`;
} else if (inProgressRoadmap.length) {
  suggestion = `Concluir a feature em andamento "${inProgressRoadmap[0][0]}" antes de puxar outro item.`;
} else if (specsWithOpenTasks.length) {
  suggestion = `Executar as tarefas abertas da spec ${specsWithOpenTasks[0].specPath}.`;
} else if (plannedRoadmap.length) {
  suggestion = `Promover o primeiro item ativo do ROADMAP: "${plannedRoadmap[0][0]}".`;
} else if (activeIdeas.length) {
  suggestion = `Triar a ideia ${activeIdeas[0][0]} e decidir se vira spec, roadmap ou descarte.`;
} else if (roadmapBacklog.length) {
  suggestion = `Escolher o primeiro item do backlog ("${roadmapBacklog[0][0]}") e criar spec se for L1/L2.`;
} else {
  suggestion = 'Projeto sem fila operacional clara. A próxima ação recomendada é revisar objetivos e alimentar ROADMAP, IDEAS ou CONCERNS com o próximo trabalho real.';
}

const planItems = [];
activeConcernPipeline.slice(0, 5).forEach((row) => {
  planItems.push(`Concern ${row[0]} (${row[2] || 'status n/a'}): ${row[5] || row[4] || row[1]}`);
});
inProgressRoadmap.slice(0, 5).forEach((row) => {
  planItems.push(`Feature em andamento: ${row[0]} (${row[3] || 'spec não informada'})`);
});
plannedRoadmap.slice(0, 5).forEach((row) => {
  planItems.push(`Feature ${row[1] || 'planejada'}: ${row[0]} (${row[3] || 'sem spec'})`);
});
activeIdeas.slice(0, 5).forEach((row) => {
  planItems.push(`Ideia ${row[0]} (${row[2]}): ${row[3] || 'definir próxima etapa'}`);
});

const report = [
  `# Relatorio WSD — ${projectName}`,
  '',
  `Gerado em: ${generatedAt}`,
  '',
  '## Resumo Executivo',
  '',
  `- Estado geral: ${overall}`,
  `- Implementação pela metade: ${inProgressRoadmap.length || specsWithOpenTasks.length ? 'sim' : 'não'}`,
  `- Plano programado: ${planItems.length ? `${planItems.length} item(ns) inferidos em ordem WSD` : 'não há fila clara registrada'}`,
  `- Ideias: ${ideaIds.length} registrada(s), ${activeIdeas.length} ativa(s) no pipeline, ${ideasWithoutPipeline.length} sem pipeline`,
  `- Concerns: ${activeConcerns.length} ativa(s), ${activeConcernPipeline.length} ativa(s) no pipeline, ${concernsWithoutPipeline.length} sem pipeline`,
  `- Sugestão do agente: ${suggestion}`,
  '',
  '## Estado Atual',
  '',
  `- Projeto: ${projectName}`,
  `- Tipo: ${projectType}`,
  `- Path: ${root}`,
  `- Branch: ${branch}`,
  `- Upstream: ${upstream}`,
  `- Default branch: ${defaultBranch}`,
  `- Remote: ${remote}`,
  `- Git: ${aheadBehind}`,
  `- Worktree: ${statusShort ? 'dirty' : 'clean'}`,
  `- Último commit: ${lastCommit}`,
  `- WSD instalado: ${wsdConfig.version || 'unknown'}`,
  `- HANDOFF: ${docs.handoff ? '+specs/HANDOFF.md presente' : 'ausente'}`,
  '',
  '## Artefatos WSD',
  '',
  `- AGENTS.md: ${docs.agents ? 'presente' : 'ausente'}`,
  `- +context.json: ${docs.context ? 'presente' : 'ausente'}`,
  `- ROADMAP.md: ${docs.roadmap ? 'presente' : 'ausente'}`,
  `- IDEAS.md / IDEAS_PIPELINE.md: ${docs.ideas ? 'presente' : 'ausente'} / ${docs.ideasPipeline ? 'presente' : 'ausente'}`,
  `- CONCERNS.md / CONCERNS_PIPELINE.md: ${docs.concerns ? 'presente' : 'ausente'} / ${docs.concernsPipeline ? 'presente' : 'ausente'}`,
  '',
  '## Implementações Em Desenvolvimento',
  '',
  ...bulletRows(inProgressRoadmap, (row) => `- ${row[0]} — status ${row[1]}, prioridade ${row[2] || 'n/a'}, spec ${row[3] || 'n/a'}`, 'nenhuma feature `in-progress` no ROADMAP'),
  '',
  '### Specs Abertas',
  '',
  ...bulletRows(openSpecs, (spec) => `- ${spec.slug} — status ${spec.status}, risco ${spec.risk}, tarefas abertas ${spec.openTasks}`, 'nenhuma spec aberta detectada'),
  '',
  '## Plano Programado',
  '',
  ...mdList(planItems, 'nenhum plano programado claro em ROADMAP, specs, concerns ou ideias'),
  '',
  '## Bloqueadores e Todos Ativos',
  '',
  ...bulletRows(blockers, (row) => `- ${row[0]} — ${row[1]} (impacto: ${row[2] || 'n/a'}, status: ${row[3] || 'n/a'})`, 'nenhum bloqueador ativo registrado'),
  '',
  ...mdList(todos, 'nenhum todo ativo em STATE.md'),
  '',
  '## Ideias',
  '',
  ...bulletRows(activeIdeas, (row) => `- ${row[0]} — ${row[1]} (status: ${row[2]}, etapa: ${row[3] || 'n/a'}, artefato: ${row[4] || 'n/a'})`, 'nenhuma ideia ativa no pipeline'),
  '',
  ...mdList(ideasWithoutPipeline.map((id) => `${id} sem linha em IDEAS_PIPELINE.md`), 'pipeline de ideias alinhado com as ideias registradas'),
  '',
  '## Concerns',
  '',
  ...bulletRows(activeConcerns, (row) => `- ${row[0]} — ${row[1]} (severidade: ${row[3] || 'n/a'}, status: ${row[4] || 'n/a'}, área: ${row[5] || 'n/a'})`, 'nenhuma concern ativa registrada'),
  '',
  '### Pipeline de Concerns',
  '',
  ...bulletRows(activeConcernPipeline, (row) => `- ${row[0]} — status ${row[2] || 'n/a'}, etapa ${row[3] || 'n/a'}, próximo passo: ${row[5] || 'n/a'}, evidência: ${row[6] || 'n/a'}`, 'nenhuma concern ativa no pipeline'),
  '',
  ...mdList(concernsWithoutPipeline.map((id) => `${id} sem linha em CONCERNS_PIPELINE.md`), 'pipeline de concerns alinhado com as concerns ativas'),
  '',
  '## Sugestão do Agente',
  '',
  suggestion,
  '',
].join('\n');

if (outputPath) {
  const targetPath = path.isAbsolute(outputPath) ? outputPath : path.join(root, outputPath);
  fs.mkdirSync(path.dirname(targetPath), { recursive: true });
  fs.writeFileSync(targetPath, `${report}\n`);
  process.stdout.write(`PASS: relatorio WSD salvo em ${outputPath}\n`);
} else {
  process.stdout.write(`${report}\n`);
}
NODE
}

_wsd_finish() {
  local auto_commit=1
  local docs_check=1
  local commit_message="chore(wsd): finish session"
  local today status_before status_after gate_wsd gate_docs gate_pr

  while [[ "$#" -gt 0 ]]; do
    case "$1" in
      -m|--message)
        [[ -n "${2-}" ]] || { echo "FAIL: $1 precisa de valor" >&2; return 1; }
        commit_message="$2"
        shift 2
        ;;
      --skip-docs-check)
        docs_check=0
        shift
        ;;
      --no-commit)
        auto_commit=0
        shift
        ;;
      help|--help|-h)
        _finish_usage
        return 0
        ;;
      *)
        echo "FAIL: argumento desconhecido em finish: $1" >&2
        _finish_usage >&2
        return 1
        ;;
    esac
  done

  echo "== WSD Finish =="
  git rev-parse --is-inside-work-tree >/dev/null 2>&1 || { echo "FAIL: wsd finish exige repositorio Git" >&2; return 1; }

  today="$(date '+%Y-%m-%d')"
  status_before="$(git status --short --untracked-files=all 2>/dev/null || true)"
  git status --short --branch
  git diff --stat
  git log -1 --date=short --pretty='last=%ad | %h | %s' 2>/dev/null || true
  _finish_sensitive_dirty_check "$status_before"

  echo ""
  echo "== WSD Finish Gates =="
  git diff --check
  echo "ok: git diff --check"

  if [[ -f scripts/wsd_check.sh ]]; then
    bash scripts/wsd_check.sh --risk L0 .
    gate_wsd="PASS"
  else
    gate_wsd="SKIPPED (scripts/wsd_check.sh ausente)"
    echo "info: $gate_wsd"
  fi

  if [[ "$docs_check" == "1" ]]; then
    if _finish_docs_check; then
      gate_docs="PASS"
      echo "ok: WSD docs check"
    else
      _docs_rc=$?
      if [[ "$_docs_rc" == "2" ]]; then
        gate_docs="SKIPPED (auditor documental WSD ausente ou docs nao instalados)"
        echo "info: $gate_docs"
      else
        return "$_docs_rc"
      fi
    fi
  else
    gate_docs="SKIPPED (--skip-docs-check)"
    echo "info: $gate_docs"
  fi

  if command -v gh >/dev/null; then
    gh pr status 2>/dev/null || true
    gate_pr="INSPECTED"
  else
    gate_pr="SKIPPED (gh ausente)"
  fi

  _finish_state_prompts "$today"

  if [[ -f +wsd/bin/wsd-snapshot.cjs ]]; then
    node +wsd/bin/wsd-snapshot.cjs 2>/dev/null && echo ">> +wsd/snapshot.json atualizado" || true
  fi

  _finish_write_handoff "$status_before" "$gate_wsd" "$gate_docs" "$gate_pr" "$auto_commit"
  echo ">> +specs/HANDOFF.md gerado"

  git diff --check
  echo "ok: git diff --check apos HANDOFF"

  if [[ "$auto_commit" == "1" ]]; then
    status_after="$(git status --short --untracked-files=all 2>/dev/null || true)"
    _finish_sensitive_dirty_check "$status_after"
    if [[ -n "$status_after" ]]; then
      git add -A
      GIT_AUTHOR_NAME="${GIT_AUTHOR_NAME:-WSD Finish}" \
      GIT_AUTHOR_EMAIL="${GIT_AUTHOR_EMAIL:-wsd-finish@example.invalid}" \
      GIT_COMMITTER_NAME="${GIT_COMMITTER_NAME:-WSD Finish}" \
      GIT_COMMITTER_EMAIL="${GIT_COMMITTER_EMAIL:-wsd-finish@example.invalid}" \
        git commit -m "$commit_message"
      echo ">> commit de fechamento criado"
    else
      echo ">> nada para commitar"
    fi

    status_after="$(git status --short --untracked-files=all 2>/dev/null || true)"
    if [[ -n "$status_after" ]]; then
      echo "FAIL: wsd finish terminou com worktree pendente:" >&2
      printf "%s\n" "$status_after" >&2
      return 1
    fi
    echo "PASS: WSD Finish completo - worktree limpo e gates aprovados"
    git log -1 --date=short --pretty='finish_commit=%ad | %h | %s'
  else
    echo "WARN: --no-commit usado; worktree pode permanecer pendente"
    git status --short --branch
  fi
}

case "$command" in
  start)
    _start_brief=0
    while [[ "$#" -gt 0 ]]; do
      case "$1" in
        --brief)
          _start_brief=1
          shift
          ;;
        help|--help|-h)
          echo "Usage: ./+wsd/bin/wsd start [--brief]"
          exit 0
          ;;
        *)
          echo "FAIL: argumento desconhecido em start: $1" >&2
          echo "Usage: ./+wsd/bin/wsd start [--brief]" >&2
          exit 1
          ;;
      esac
    done
    if [[ "$_start_brief" == "1" ]]; then
      echo "== WSD Start Brief =="
      printf "path: %s\n" "$project_root"
      printf "branch: %s\n" "$(git rev-parse --abbrev-ref HEAD 2>/dev/null || echo unknown)"
      printf "upstream: %s\n" "$(git rev-parse --abbrev-ref --symbolic-full-name '@{u}' 2>/dev/null || echo missing)"
      if [[ -n "$(git status --short 2>/dev/null)" ]]; then
        echo "worktree: dirty"
      else
        echo "worktree: clean"
      fi
      printf "wsd_version: %s\n" "$(_json_get +wsd/config.json version 2>/dev/null || echo unknown)"
      [[ -f AGENTS.md ]] && echo "agents: present" || echo "agents: missing"
      [[ -f +context.json ]] && echo "context: present" || echo "context: missing"
      [[ -f +specs/project/STATE.md ]] && echo "state: present" || echo "state: missing"
      [[ -f +specs/project/CONCERNS.md ]] && echo "concerns: present" || echo "concerns: missing"
      [[ -f +specs/project/CONCERNS_PIPELINE.md ]] && echo "concerns_pipeline: present" || echo "concerns_pipeline: missing"
      if [[ -f +specs/project/CONCERNS_PIPELINE.md ]]; then
        _concerns_active="$(grep -E '^\| \\[?CONC-[0-9][0-9][0-9]' +specs/project/CONCERNS_PIPELINE.md 2>/dev/null | grep -Ev '`(resolved|accepted-risk|obsolete)`' | wc -l | tr -d ' ' || true)"
        [[ -n "$_concerns_active" ]] || _concerns_active=0
        printf "concerns_active: %s\n" "$_concerns_active"
      fi
      [[ -f +specs/HANDOFF.md ]] && echo "handoff: present" || echo "handoff: missing"
      _features_count="$(find +specs/features -maxdepth 2 -type f -name 'spec.md' 2>/dev/null | wc -l | tr -d ' ' || true)"
      [[ -n "$_features_count" ]] || _features_count=0
      printf "features: %s\n" "$_features_count"
    else
      echo "== WSD Start =="
      git status --short --branch
      git branch -vv
      git remote -v
      git remote show origin 2>/dev/null || true
      if [[ -f scripts/wsd_check.sh ]]; then
        bash scripts/wsd_check.sh --risk L0 .
      fi
      if [[ -f +specs/HANDOFF.md ]]; then
        echo "-- HANDOFF.md (last session) --"
        head -20 +specs/HANDOFF.md
      fi
      find +specs/features -maxdepth 2 -type f -name 'spec.md' 2>/dev/null | sort || true
      find +specs/quick -maxdepth 1 -type f -name '*.md' 2>/dev/null | sort || true
      gh pr list --state open --limit 20 2>/dev/null || true
    fi
    ;;
  check)
    if [[ -f scripts/wsd_check.sh ]]; then
      bash scripts/wsd_check.sh "$@"
    else
      echo "FAIL: scripts/wsd_check.sh not found" >&2
      exit 1
    fi
    ;;
  finish)
    _wsd_finish "$@"
    ;;
  relatorio|report|status-report|resumo)
    _wsd_relatorio "$@"
    ;;
  doctor)
    echo "== WSD Doctor =="
    test -f +wsd/config.json && echo "ok: +wsd/config.json" || echo "missing: +wsd/config.json"
    test -f +wsd/docs/10_matriz_sincronizacao_notas.md && echo "ok: +wsd/docs/10_matriz_sincronizacao_notas.md" || echo "missing: +wsd/docs/10_matriz_sincronizacao_notas.md"
    test -f +wsd/schemas/context.schema.json && echo "ok: +wsd/schemas/context.schema.json" || echo "missing: +wsd/schemas/context.schema.json"
    test -x +wsd/bin/wsd-validate-context.cjs && echo "ok: +wsd/bin/wsd-validate-context.cjs" || echo "missing: +wsd/bin/wsd-validate-context.cjs"
    test -f AGENTS.md && echo "ok: AGENTS.md" || echo "missing: AGENTS.md"
    if [[ -f AGENTS.md ]]; then
      if grep -q 'WSD Codex Bootstrap' AGENTS.md && grep -q 'codex-prompt' AGENTS.md && grep -q '+context.json' AGENTS.md; then
        echo "ok: AGENTS.md WSD Codex Bootstrap"
      else
        echo "warn: AGENTS.md sem bloco WSD Codex Bootstrap atualizado"
      fi
    fi
    test -f +context.json && echo "ok: +context.json" || echo "missing: +context.json"
    test -d +specs && echo "ok: +specs" || echo "missing: +specs"
    test -f +specs/project/STATE.md && echo "ok: +specs/project/STATE.md" || echo "missing: +specs/project/STATE.md"
    test -f +specs/project/PROJECT.md && echo "ok: +specs/project/PROJECT.md" || echo "missing: +specs/project/PROJECT.md"
    if [[ -d +specs/codebase ]]; then
      echo "ok: +specs/codebase (brownfield)"
    else
      echo "info: +specs/codebase absent (greenfield install)"
    fi
    command -v git >/dev/null && echo "ok: git" || echo "missing: git"
    command -v node >/dev/null && echo "ok: node" || echo "missing: node (schema validation will skip)"
    command -v python3 >/dev/null && echo "ok: python3" || echo "missing: python3"
    command -v gh >/dev/null && echo "ok: gh optional" || echo "missing: gh optional"
    command -v codex >/dev/null && echo "ok: codex optional" || echo "missing: codex optional"
    echo "ok: git namespace available (doctor, preflight, pr-check)"
    if [[ -f +wsd/party-mode/agents-wsd.csv ]]; then
      echo "ok: party-mode instalado"
    else
      echo "info: party-mode ausente (reinstale com --force para instalar)"
    fi
    for hook in pre-commit commit-msg pre-push; do
      if [[ -x ".git/hooks/$hook" ]]; then
        echo "ok: .git/hooks/$hook"
      else
        echo "missing: .git/hooks/$hook (run: ./+wsd/bin/wsd hooks)"
      fi
    done
    ;;
  hooks)
    if [[ -d scripts/git-hooks ]]; then
      [[ -d .git/hooks ]] || { echo "FAIL: .git/hooks not found — is this a Git repo?" >&2; exit 1; }
      for hook in scripts/git-hooks/*; do
        hookname="$(basename "$hook")"
        cp "$hook" ".git/hooks/$hookname"
        chmod +x ".git/hooks/$hookname"
        echo "ok: installed .git/hooks/$hookname"
      done
    else
      echo "FAIL: scripts/git-hooks not found — run wsd-method install --force to regenerate" >&2
      exit 1
    fi
    ;;
  update)
    if [[ ! -f +wsd/config.json ]]; then
      echo "FAIL: +wsd/config.json not found — run wsd-method install first" >&2
      exit 1
    fi
    _wsd_src="$(python3 -c "import json; print(json.load(open('+wsd/config.json')).get('wsd_source',''))" 2>/dev/null || echo '')"
    if [[ -n "$_wsd_src" && -f "$_wsd_src/bin/wsd-method.js" ]]; then
      node "$_wsd_src/bin/wsd-method.js" update --directory .
    else
      echo "warn: wsd_source ausente ou invalido em +wsd/config.json"
      echo "Execute: node /caminho/para/wsd/bin/wsd-method.js update --directory ."
    fi
    ;;
  git)
    subcommand="${1:-help}"
    shift || true
    mode="$(_git_mode)"
    case "$subcommand" in
      doctor)
        echo "== WSD Git Doctor =="
        echo "mode: $mode"
        git rev-parse --is-inside-work-tree >/dev/null 2>&1 || { echo "FAIL: not a Git repository" >&2; exit 1; }
        branch="$(_git_current_branch)"
        upstream="$(_git_upstream)"
        remote="$(git remote get-url origin 2>/dev/null || true)"
        default_branch="$(_context_get git_governance.default_branch)"
        [[ -n "$default_branch" ]] || default_branch="$(_context_get repository.default_branch)"
        echo "branch: ${branch:-unknown}"
        echo "upstream: ${upstream:-missing}"
        echo "remote: ${remote:-missing}"
        echo "default_branch: ${default_branch:-unknown}"
        if [[ "$mode" == "full" ]]; then
          if command -v gh >/dev/null; then
            echo "ok: gh available"
            gh auth status >/dev/null 2>&1 && echo "ok: gh authenticated" || echo "warn: gh not authenticated"
          else
            echo "warn: gh missing (full mode can still use manual PR flow)"
          fi
          if [[ "$remote" == *github.com* ]]; then
            echo "ok: origin looks like GitHub"
          else
            echo "warn: origin is not a GitHub remote"
          fi
        fi
        ;;
      preflight)
        echo "== WSD Git Preflight =="
        fail_count=0
        git rev-parse --is-inside-work-tree >/dev/null 2>&1 || { echo "FAIL: not a Git repository" >&2; exit 1; }
        branch="$(_git_current_branch)"
        upstream="$(_git_upstream)"
        status_short="$(git status --short)"
        canonical_path="$(_context_get environment.canonical_path)"
        canonical_host="$(_context_get environment.canonical_host)"
        current_host="$(hostname 2>/dev/null || true)"
        echo "mode: $mode"
        echo "branch: ${branch:-unknown}"
        echo "upstream: ${upstream:-missing}"
        if [[ -n "$canonical_path" && "$canonical_path" != "$(pwd)" ]]; then
          echo "warn: current path differs from canonical_path ($canonical_path)"
        fi
        if [[ -n "$canonical_host" && -n "$current_host" && "$canonical_host" != "$current_host" ]]; then
          echo "warn: current host differs from canonical_host ($canonical_host)"
        fi
        if [[ -n "$status_short" ]]; then
          echo "FAIL: worktree is dirty"
          printf "%s\n" "$status_short"
          fail_count=$((fail_count + 1))
        else
          echo "ok: worktree clean"
        fi
        if [[ -z "$upstream" ]]; then
          echo "warn: upstream missing"
        fi
        [[ "$fail_count" -eq 0 ]] || exit 1
        ;;
      pr-check)
        echo "== WSD Git PR Check =="
        git rev-parse --is-inside-work-tree >/dev/null 2>&1 || { echo "FAIL: not a Git repository" >&2; exit 1; }
        fail_count=0
        branch="$(_git_current_branch)"
        upstream="$(_git_upstream)"
        remote="$(git remote get-url origin 2>/dev/null || true)"
        default_branch="$(_context_get git_governance.default_branch)"
        [[ -n "$default_branch" ]] || default_branch="$(_context_get repository.default_branch)"
        [[ -n "$default_branch" ]] || default_branch="main"
        base_ref="$(_git_base_ref "$default_branch")"
        echo "mode: $mode"
        echo "branch: ${branch:-unknown}"
        echo "upstream: ${upstream:-missing}"
        echo "remote: ${remote:-missing}"
        echo "base_ref: ${base_ref:-unknown}"
        if [[ "$branch" == "$default_branch" || "$branch" == "main" || "$branch" == "master" ]]; then
          echo "FAIL: PR deve sair de branch dedicada, nao de $branch"
          fail_count=$((fail_count + 1))
        fi
        if [[ -n "$(git status --short 2>/dev/null)" ]]; then
          echo "FAIL: worktree is dirty"
          fail_count=$((fail_count + 1))
        fi
        if ! _git_has_changes_for_pr "$base_ref"; then
          echo "FAIL: nao ha commits ahead de ${base_ref} prontos para PR"
          fail_count=$((fail_count + 1))
        fi
        if [[ "$mode" == "full" && "$remote" != *github.com* ]]; then
          echo "warn: origin nao parece ser GitHub"
        fi
        if [[ "$mode" == "full" && -z "$upstream" ]]; then
          echo "warn: upstream ausente; use git push -u origin $branch antes do PR"
        fi
        [[ "$fail_count" -eq 0 ]] || exit 1
        echo "ok: pr-check passed"
        ;;
      help|--help|-h)
        echo "Usage: ./+wsd/bin/wsd git doctor|preflight|pr-check"
        ;;
      *)
        echo "Unknown WSD git command: $subcommand" >&2
        echo "Usage: ./+wsd/bin/wsd git doctor|preflight|pr-check" >&2
        exit 1
        ;;
    esac
    ;;
  party)
    subcommand="${1:-help}"
    shift || true
    case "$subcommand" in
      status)
        if [[ -f +wsd/party-mode/agents-wsd.csv ]]; then
          count=$(tail -n +2 +wsd/party-mode/agents-wsd.csv | grep -c '' || true)
          echo "ok: party-mode instalado — $count agentes disponíveis"
        else
          echo "FAIL: party-mode não instalado — +wsd/party-mode/agents-wsd.csv ausente" >&2
          exit 1
        fi
        ;;
      list-agents)
        [[ -f +wsd/party-mode/agents-wsd.csv ]] || { echo "FAIL: +wsd/party-mode/agents-wsd.csv ausente" >&2; exit 1; }
        command -v python3 >/dev/null || { echo "FAIL: python3 necessário para list-agents" >&2; exit 1; }
        python3 - <<'PY'
import csv
with open("+wsd/party-mode/agents-wsd.csv", encoding="utf-8") as f:
    for row in csv.DictReader(f):
        icon = row.get("icon", "•")
        name = row.get("displayName", row.get("name", "?"))
        domain = row.get("domain", "?")
        title = row.get("title", "")
        print(f"{icon} {name:<20s} ({domain:<4s}) — {title}")
PY
        ;;
      when-to-use)
        cat <<'USAGE'
== WSD Party Mode — Quando Usar ==

L0 trivial?        → Skip (use quick-flow solo)
Em EXECUTE?        → Skip (spec já diz o que fazer)
Já decidido?       → Skip (use 1 agente para validar)
Hotfix urgente?    → Skip

Contexto              Agentes selecionados              Tempo
SPECIFY/Brainstorm    analyst + pm + brainstorming-coach ~20 min
DESIGN/Arquitetura    architect + dev + module-builder   ~25 min
RISK L1               qa + architect + pm               ~20 min
RISK L2 (obrigatório) tea + test-architect + sys-arch   ~30 min
CODE REVIEW           dev + test-architect + architect  ~20 min
PROCESS/Ciclo         wsd-master + scrum-master + workflow-builder ~15 min

Comando Claude Code: /wsd-party-mode
USAGE
        ;;
      help|*)
        echo "Usage: ./+wsd/bin/wsd party <subcommand>"
        echo "  status       — verifica se party-mode está instalado"
        echo "  list-agents  — lista os 26 agentes disponíveis"
        echo "  when-to-use  — decision tree de quando usar"
        ;;
    esac
    ;;
  snapshot)
    if [[ ! -f +wsd/bin/wsd-snapshot.cjs ]]; then
      echo "FAIL: +wsd/bin/wsd-snapshot.cjs não encontrado — reinstale com wsd-method install --force" >&2
      exit 1
    fi
    node +wsd/bin/wsd-snapshot.cjs
    ;;
  lovable)
    subcommand="${1:-help}"
    shift || true
    _lovable_enabled="$(_context_get lovable_integration.enabled)"
    case "$subcommand" in
      doctor)
        echo "== WSD Lovable Doctor =="
        if [[ "$_lovable_enabled" != "true" ]]; then
          echo "FAIL: +context.json não declara lovable_integration.enabled=true" >&2
          echo "Hint: reinstale com --profile lovable_tanstack_start, ou edite +context.json manualmente." >&2
          exit 1
        fi
        pass_lovable=0
        if [[ -f package-lock.json ]]; then
          echo "FAIL: package-lock.json presente — causa raiz do Preview travado (Lovable é Bun-puro)" >&2
          echo "Fix: git rm package-lock.json && git commit -m 'chore(deps): remove package-lock.json (Lovable é bun-first)'" >&2
          pass_lovable=1
        else
          echo "ok: package-lock.json ausente"
        fi
        if [[ ! -f bun.lock ]]; then
          echo "FAIL: bun.lock ausente — rode 'bun install' para gerar" >&2
          pass_lovable=1
        else
          echo "ok: bun.lock presente"
        fi
        if ! command -v bun >/dev/null 2>&1; then
          echo "warn: bun não está no PATH local — agente não conseguirá rodar 'bun install' aqui"
        else
          echo "ok: bun no PATH ($(bun --version 2>/dev/null))"
        fi
        if [[ $pass_lovable -eq 0 ]]; then
          echo "PASS: lovable doctor"
        else
          exit 1
        fi
        ;;
      bootstrap)
        # Desliga "automatically delete head branches" no repo do GitHub.
        # Sem isso, mergear PRs Lovable pode deletar branches que a Lovable depende.
        if [[ "$_lovable_enabled" != "true" ]]; then
          echo "FAIL: +context.json não declara lovable_integration.enabled=true" >&2
          exit 1
        fi
        repo_name="$(_context_get repository.name)"
        if [[ -z "$repo_name" ]]; then
          echo "FAIL: +context.json não tem repository.name (esperado owner/repo)" >&2
          exit 1
        fi
        if ! command -v gh >/dev/null 2>&1; then
          echo "FAIL: gh CLI não está instalado (necessário para PATCH /repos/${repo_name})" >&2
          exit 1
        fi
        echo "== WSD Lovable Bootstrap =="
        echo "Desligando delete_branch_on_merge em ${repo_name}..."
        if gh api -X PATCH "/repos/${repo_name}" -f delete_branch_on_merge=false >/dev/null; then
          echo "ok: delete_branch_on_merge=false aplicado em ${repo_name}"
        else
          echo "FAIL: PATCH falhou — verifique autenticação gh e permissões no repo" >&2
          exit 1
        fi
        ;;
      help|*)
        cat <<USAGE
Usage: ./+wsd/bin/wsd lovable <subcommand>
  doctor     — verifica invariantes Lovable (package-lock.json ausente, bun.lock presente)
  bootstrap  — aplica configuração GitHub no repo (delete_branch_on_merge=false) via gh api
USAGE
        ;;
    esac
    ;;
  version)
    _wsd_version_report "$@"
    ;;
  loop)
    _wsd_loop "$@"
    ;;
  codex-prompt)
    _wsd_codex_prompt "$@"
    ;;
  codex)
    _wsd_codex "$@"
    ;;
  codex-shortcuts)
    _wsd_codex_shortcuts "$@"
    ;;
  shortcuts)
    _wsd_shortcuts "$@"
    ;;
  help|--help|-h)
    echo "Usage: ./+wsd/bin/wsd start|check|finish|relatorio|doctor|hooks|update|git|party|snapshot|version|lovable|loop|codex-prompt|codex|codex-shortcuts|shortcuts"
    echo "       ./+wsd/bin/wsd version [--inventory|--scan] [--json] [--path <dir>] [--max-depth <n>]"
    echo "       ./+wsd/bin/wsd loop plan|once|run|status|stop"
    echo "       ./+wsd/bin/wsd relatorio [--save|--output <file>]"
    echo "       ./+wsd/bin/wsd codex-prompt|codex [--task <text>] [--feature <slug>]"
    ;;
  *)
    echo "Unknown WSD command: $command" >&2
    echo "Usage: ./+wsd/bin/wsd start|check|finish|relatorio|doctor|hooks|update|git|party|snapshot|version|lovable|loop|codex-prompt|codex|codex-shortcuts|shortcuts" >&2
    exit 1
    ;;
esac
